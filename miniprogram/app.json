{
  "pages": [
    "pages/home/index",
    "pages/daily/index",
    "pages/statistics/index",
    "pages/health-center/index",
    "pages/growth-center/index",
    "pages/profile/index"
  ],
  "subpackages": [
    {
      "root": "pages/feeding",
      "name": "feeding",
      "pages": ["add/index"]
    },
    {
      "root": "pages/sleep",
      "name": "sleep",
      "pages": ["add/index"]
    },
    {
      "root": "pages/diaper",
      "name": "diaper",
      "pages": ["add/index"]
    },
    {
      "root": "pages/health",
      "name": "health",
      "pages": ["add/index"]
    },
    {
      "root": "pages/milestone",
      "name": "milestone",
      "pages": ["index"]
    },
    {
      "root": "pages/report",
      "name": "report",
      "pages": ["index"]
    },
    {
      "root": "pages/ai-advisor",
      "name": "ai-advisor",
      "pages": ["index"]
    },
    {
      "root": "pages/family",
      "name": "family",
      "pages": ["index"]
    }
  ],
  "preloadRule": {
    "pages/daily/index": {
      "network": "all",
      "packages": ["feeding", "sleep", "diaper"]
    },
    "pages/health-center/index": {
      "network": "all",
      "packages": ["health"]
    },
    "pages/growth-center/index": {
      "network": "all",
      "packages": ["milestone"]
    }
  },
  "tabBar": {
    "color": "@tabFontColor",
    "selectedColor": "@tabSelectedColor",
    "backgroundColor": "@tabBgColor",
    "borderStyle": "@tabBorderStyle",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "assets/icons/home.png",
        "selectedIconPath": "assets/icons/home-active.png"
      },
      {
        "pagePath": "pages/daily/index",
        "text": "日常记录",
        "iconPath": "assets/icons/daily.png",
        "selectedIconPath": "assets/icons/daily-active.png"
      },
      {
        "pagePath": "pages/health-center/index",
        "text": "健康监测",
        "iconPath": "assets/icons/health-center.png",
        "selectedIconPath": "assets/icons/health-center-active.png"
      },
      {
        "pagePath": "pages/growth-center/index",
        "text": "成长发育",
        "iconPath": "assets/icons/growth-center.png",
        "selectedIconPath": "assets/icons/growth-center-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "assets/icons/profile.png",
        "selectedIconPath": "assets/icons/profile-active.png"
      }
    ]
  },
  "window": {
    "backgroundTextStyle": "@bgTxtStyle",
    "navigationBarBackgroundColor": "@navBgColor",
    "navigationBarTitleText": "宝宝养护追踪",
    "navigationBarTextStyle": "@navTxtStyle",
    "backgroundColor": "@bgColor"
  },
  "darkmode": true,
  "themeLocation": "theme.json",
  "lazyCodeLoading": "requiredComponents",
  "usingComponents": {
    "t-icon": "tdesign-miniprogram/icon/icon",
    "t-input": "tdesign-miniprogram/input/input",
    "t-textarea": "tdesign-miniprogram/textarea/textarea",
    "t-date-time-picker": "tdesign-miniprogram/date-time-picker/date-time-picker",
    "t-popup": "tdesign-miniprogram/popup/popup",
    "t-tabs": "tdesign-miniprogram/tabs/tabs",
    "t-tab-panel": "tdesign-miniprogram/tab-panel/tab-panel",
    "baby-switcher": "/components/baby-switcher/index"
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "cloud": true
}
