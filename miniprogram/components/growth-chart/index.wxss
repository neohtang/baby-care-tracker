/* components/growth-chart/index.wxss */
/* 生长曲线图组件样式 */

.growth-chart-wrap {
  padding: 0;
}

/* 图表头部 */
.chart-header {
  display: flex;
  justify-content: flex-end;
  padding: 0 8rpx 16rpx;
}

/* 图例 */
.chart-legend {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-dot-data {
  background: #7C6FE0;
  box-shadow: 0 0 0 3rpx rgba(124, 111, 224, 0.2);
}

.legend-band {
  width: 24rpx;
  height: 10rpx;
  border-radius: 3rpx;
  background: linear-gradient(90deg, rgba(124, 111, 224, 0.1), rgba(124, 111, 224, 0.2));
  border: 1rpx solid rgba(124, 111, 224, 0.25);
}

.legend-text {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* Canvas 容器 */
.chart-canvas-wrap {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFFFFF;
}

.chart-canvas {
  display: block;
}

/* 无数据遮罩 */
.chart-empty-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(4rpx);
}

.chart-empty-text {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
}

.chart-empty-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}
