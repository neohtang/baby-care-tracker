<!--components/growth-chart/index.wxml-->
<!--生长曲线图组件：Canvas 2D 绘制 WHO 标准百分位区间 + 宝宝数据-->

<view class="growth-chart-wrap">
  <!-- 图表头部信息 -->
  <view class="chart-header">
    <view class="chart-legend">
      <view class="legend-item">
        <view class="legend-dot legend-dot-data"></view>
        <text class="legend-text">宝宝数据</text>
      </view>
      <view class="legend-item">
        <view class="legend-band"></view>
        <text class="legend-text">WHO 参考范围</text>
      </view>
    </view>
  </view>

  <!-- Canvas 画布 -->
  <view class="chart-canvas-wrap" style="width: {{width}}rpx; height: {{height}}rpx;">
    <canvas
      id="{{canvasId}}"
      canvas-id="{{canvasId}}"
      type="2d"
      class="chart-canvas"
      style="width: 100%; height: 100%;"
    ></canvas>

    <!-- 无数据遮罩 -->
    <view wx:if="{{babyData.length === 0 && whoData.length === 0}}" class="chart-empty-overlay">
      <text class="chart-empty-text">暂无数据</text>
      <text class="chart-empty-hint">添加测量记录后将在此显示生长曲线</text>
    </view>
  </view>
</view>
