/* components/baby-avatar/index.wxss */
/* 宝宝头像组件样式 */

.baby-avatar-wrap {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 头像外环——渐变边框效果 */
.avatar-ring {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 111, 224, 0.2);
  transition: transform 0.2s ease;
}

.avatar-ring:active {
  transform: scale(0.95);
}

/* 头像图片 */
.avatar-img {
  border-radius: 50%;
  background: #FFFFFF;
}

/* 无头像占位 */
.avatar-placeholder {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #C8956C;
}

.avatar-initial {
  color: #FFFFFF;
  font-weight: 600;
}

.avatar-initial-img {
  width: 50%;
  height: 50%;
}

/* 月龄标签 */
.age-badge {
  margin-top: 8rpx;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #C8956C, #D4A97A);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(200, 149, 108, 0.25);
}

.age-text {
  font-size: 20rpx;
  color: #FFFFFF;
  white-space: nowrap;
  font-weight: 500;
}
