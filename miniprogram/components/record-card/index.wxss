/* components/record-card/index.wxss */
/* 通用记录卡片组件样式 */

.record-card-wrap {
  margin-bottom: 12rpx;
}

.record-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 异常状态 */
.record-alert {
  border-left: 6rpx solid #F87171;
  padding-left: 18rpx;
}

/* 主体布局 */
.record-main {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

/* 图标 */
.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

/* 内容区 */
.record-body {
  flex: 1;
  min-width: 0;
}

/* 头部：标题 + 时间 */
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2E22;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 详情 */
.record-detail {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* 标签组 */
.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.record-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

/* 异常提示 */
.record-alert-tip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 10rpx;
  padding: 6rpx 12rpx;
  background: #FEF2F2;
  border-radius: 8rpx;
}

.alert-icon {
  font-size: 22rpx;
}

/* SVG 图标图片 */
.record-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.alert-icon-img {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.alert-text {
  font-size: 22rpx;
  color: #DC2626;
}

/* 左滑操作按钮 */
.swipe-actions {
  display: flex;
  height: 100%;
}

.swipe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 100%;
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.swipe-edit {
  background: #60A5FA;
}

.swipe-del {
  background: #F87171;
}

/* 兼容 TDesign swipe-cell 的右侧按钮样式 */
.swipe-delete-btn {
  background: #F87171 !important;
}

.swipe-edit-btn {
  background: #60A5FA !important;
}
