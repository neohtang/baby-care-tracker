/* components/timer/index.wxss */
/* 计时器组件样式 */

.timer-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.timer-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 24rpx;
}

/* 圆形进度环容器 */
.timer-circle {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* 底圈 */
.circle-bg {
  position: absolute;
  border-radius: 50%;
  border: 6rpx solid;
}

/* 进度弧线 */
.circle-progress {
  position: absolute;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, #000 56%);
  -webkit-mask: radial-gradient(transparent 55%, #000 56%);
  transition: background 0.3s linear;
}

.circle-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: #FFFFFF;
}

/* 时间显示 */
.timer-display {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-text-wrap {
  display: flex;
  align-items: baseline;
}

.time-digits {
  font-size: 64rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
  letter-spacing: 2rpx;
}

.time-colon {
  font-size: 56rpx;
  font-weight: 700;
  margin: 0 2rpx;
  animation: blink 1s ease-in-out infinite;
}

.time-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

/* 脉冲点动画 */
.pulse-dot {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  animation: pulse 1.5s ease-in-out infinite;
  z-index: 3;
}

/* 控制按钮组 */
.timer-controls {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  padding: 20rpx 48rpx;
}

.ctrl-btn:active {
  transform: scale(0.92);
  opacity: 0.85;
}

.ctrl-btn-primary {
  min-width: 200rpx;
  box-shadow: 0 6rpx 20rpx rgba(200, 149, 108, 0.3);
}

.ctrl-btn-pause {
  box-shadow: 0 4rpx 12rpx rgba(200, 149, 108, 0.15);
  border: 2rpx solid rgba(200, 149, 108, 0.3);
}

.ctrl-btn-stop {
  background: #FEF2F2;
  color: #F87171;
  border: 2rpx solid rgba(248, 113, 113, 0.2);
}

.ctrl-btn-reset {
  background: #F5F5F5;
  color: #6B7280;
}

/* 动画 */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }
  50% {
    opacity: 0.5;
    transform: translateX(-50%) scale(1.6);
  }
}
