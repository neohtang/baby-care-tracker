/* components/stat-summary/index.wxss */
/* 统计摘要组件样式 */

.stat-summary {
  padding: 0;
}

.stat-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2E22;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

/* 网格布局 */
.stat-grid {
  display: grid;
  gap: 16rpx;
}

.stat-grid-card .stat-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 单项 */
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  text-align: center;
  position: relative;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.stat-clickable:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* 图标 */
.stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.stat-icon-img {
  width: 36rpx;
  height: 36rpx;
}

/* 数值 */
.stat-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-unit {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
}

/* 标签 */
.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

/* 趋势指示 */
.stat-trend {
  display: flex;
  align-items: center;
  gap: 2rpx;
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  font-size: 18rpx;
}

.trend-up {
  background: #D1FAE5;
  color: #059669;
}

.trend-down {
  background: #FEE2E2;
  color: #DC2626;
}

.trend-stable {
  background: #F3F4F6;
  color: #6B7280;
}

.trend-arrow {
  font-weight: 700;
  font-size: 20rpx;
}

.trend-text {
  font-size: 18rpx;
}
