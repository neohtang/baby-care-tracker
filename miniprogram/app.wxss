/**
 * Baby Care Tracker - 全局样式
 * 主题：Tender Bloom（温柔绽放）
 * 设计理念：温暖而不幼稚，专业而不冰冷
 * 融合北欧简约美学与东方温馨气质
 */

/* ========== Tender Bloom 主题变量 ========== */
page {
  /* 主色系 — 温暖奶茶棕 */
  --td-brand-color: #C8956C;
  --td-brand-color-light: #D4A97A;
  --td-brand-color-focus: #E8C4A0;
  --td-brand-color-active: #B8854F;
  --td-brand-color-disabled: #DCC5AD;

  /* 功能色 — 温和自然 */
  --td-success-color: #7EBEA5;
  --td-warning-color: #F0B44A;
  --td-error-color: #E8736C;
  --td-info-color: #7CAFD4;

  /* 背景色 — 香草奶白 */
  --td-bg-color-page: #FDF8F3;
  --td-bg-color-container: #FFFFFF;
  --td-bg-color-secondarycontainer: #F5EDE4;

  /* 文字色 — 浓缩咖啡系 */
  --td-text-color-primary: #3D2E22;
  --td-text-color-secondary: #8B7B6B;
  --td-text-color-placeholder: #B5A89C;

  /* 圆角 */
  --td-radius-default: 16rpx;
  --td-radius-large: 24rpx;
  --td-radius-round: 999rpx;

  /* === 自定义品牌扩展变量 === */

  /* 辅色 — 薄荷绿（健康/生长/活力） */
  --color-mint: #7EBEA5;
  --color-mint-light: #E8F5EE;
  --color-mint-bg: #F0F9F5;

  /* 点缀色 — 蜜桃粉（温柔/母性/关爱） */
  --color-peach: #F5A5B8;
  --color-peach-light: #FDE8ED;
  --color-peach-bg: #FFF0F4;

  /* 警示色 — 琥珀蜜黄 */
  --color-amber: #F0B44A;
  --color-amber-light: #FEF3D6;
  --color-amber-bg: #FFFBF0;

  /* 错误色 — 珊瑚红 */
  --color-coral: #E8736C;
  --color-coral-light: #FDECEB;
  --color-coral-bg: #FFF5F4;

  /* 信息色 — 天蓝雾 */
  --color-sky: #7CAFD4;
  --color-sky-light: #E3F0F9;
  --color-sky-bg: #F0F7FC;

  /* 渐变 */
  --gradient-primary: linear-gradient(135deg, #C8956C 0%, #D4A97A 50%, #E8C4A0 100%);
  --gradient-warm: linear-gradient(135deg, #FDF8F3 0%, #F5EDE4 100%);
  --gradient-mint: linear-gradient(135deg, #7EBEA5 0%, #A8D8C4 100%);
  --gradient-peach: linear-gradient(135deg, #F5A5B8 0%, #FAC8D4 100%);
  --gradient-sky: linear-gradient(135deg, #7CAFD4 0%, #A3CBE5 100%);
  --gradient-amber: linear-gradient(135deg, #F0B44A 0%, #F5CC7A 100%);

  /* 阴影 */
  --shadow-card: 0 4rpx 20rpx rgba(200, 149, 108, 0.08);
  --shadow-card-hover: 0 8rpx 32rpx rgba(200, 149, 108, 0.14);
  --shadow-card-sm: 0 2rpx 12rpx rgba(200, 149, 108, 0.06);
  --shadow-float: 0 8rpx 40rpx rgba(200, 149, 108, 0.18);

  /* 模块专属色（用于图标背景、时间线等） */
  --module-feeding: #C8956C;
  --module-feeding-bg: #FFF5ED;
  --module-sleep: #7CAFD4;
  --module-sleep-bg: #F0F7FC;
  --module-diaper: #7EBEA5;
  --module-diaper-bg: #F0F9F5;
  --module-health: #F0B44A;
  --module-health-bg: #FFFBF0;
  --module-growth: #F5A5B8;
  --module-growth-bg: #FFF0F4;
  --module-vaccine: #9B8EC4;
  --module-vaccine-bg: #F5F2FA;
  --module-milestone: #D4A97A;
  --module-milestone-bg: #FFF8F0;

  /* 页面基础样式 */
  background-color: #FDF8F3;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #3D2E22;
  line-height: 1.6;
}

/* ========== 通用工具类 ========== */

/* 卡片容器 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-card-hover);
}

.card-sm {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: var(--shadow-card-sm);
}

/* 渐变背景 */
.gradient-primary {
  background: var(--gradient-primary);
}

.gradient-warm {
  background: var(--gradient-warm);
}

.gradient-mint {
  background: var(--gradient-mint);
}

.gradient-peach {
  background: var(--gradient-peach);
}

.gradient-sky {
  background: var(--gradient-sky);
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2E22;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.section-subtitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2E22;
  margin-bottom: 16rpx;
}

.text-secondary {
  font-size: 26rpx;
  color: #8B7B6B;
}

.text-hint {
  font-size: 24rpx;
  color: #B5A89C;
}

.text-brand {
  color: #C8956C;
}

/* Flex 布局工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 32rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.mb-lg { margin-bottom: 32rpx; }
.ml-sm { margin-left: 16rpx; }
.mr-sm { margin-right: 16rpx; }
.px-md { padding-left: 24rpx; padding-right: 24rpx; }
.py-md { padding-top: 24rpx; padding-bottom: 24rpx; }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #F0E8DF;
  margin: 24rpx 0;
}

/* 标签/徽章 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: #FFF5ED;
  color: #C8956C;
}

.tag-success {
  background: var(--color-mint-light);
  color: #5A9E82;
}

.tag-warning {
  background: var(--color-amber-light);
  color: #C8930A;
}

.tag-error {
  background: var(--color-coral-light);
  color: #C85650;
}

.tag-info {
  background: var(--color-sky-light);
  color: #5A8FB4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state-text {
  font-size: 28rpx;
  color: #B5A89C;
  margin-top: 24rpx;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  z-index: 100;
}

.fab-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  transition: transform 0.15s ease;
}

.fab-btn:active {
  transform: scale(0.92);
}

.fab-btn-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes ripple {
  0% { transform: scale(1); opacity: 0.4; }
  100% { transform: scale(1.8); opacity: 0; }
}

.animate-scale {
  transition: transform 0.15s ease;
}

.animate-scale:active {
  transform: scale(0.96);
}

.animate-card-hover {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 列表项通用样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  transition: background 0.15s ease;
}

.list-item:active {
  background: #FAF5F0;
}

.list-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.list-item-content {
  flex: 1;
  min-width: 0;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #3D2E22;
  line-height: 1.4;
}

.list-item-desc {
  font-size: 24rpx;
  color: #8B7B6B;
  margin-top: 4rpx;
  line-height: 1.4;
}

.list-item-arrow {
  color: #B5A89C;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 底部弹窗通用样式 */
.popup-content {
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2E22;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B5A89C;
}

/* 主按钮 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 20rpx;
  background: var(--gradient-primary);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.25);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(200, 149, 108, 0.2);
}

.btn-primary[disabled] {
  background: #DCC5AD;
  box-shadow: none;
}

/* 次要按钮 */
.btn-secondary {
  width: 100%;
  height: 96rpx;
  border-radius: 20rpx;
  background: #F5EDE4;
  color: #C8956C;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: transform 0.15s ease;
}

.btn-secondary:active {
  transform: scale(0.98);
  background: #EDE3D8;
}

/* 表单项 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #8B7B6B;
  margin-bottom: 12rpx;
}

.form-input {
  height: 88rpx;
  background: #FAF5F0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #3D2E22;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
}

.form-input:focus {
  border-color: #C8956C;
  background: #FFFFFF;
}

/* 安全区域适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: #FDF8F3;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
