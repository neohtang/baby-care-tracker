/**
 * Baby Care Tracker - 全局样式
 * 设计风格：温馨母婴风，柔和圆角卡片，浅暖色渐变
 */

/* ========== TDesign 主题变量覆盖 ========== */
page {
  /* 主色系 */
  --td-brand-color: #7C6FE0;
  --td-brand-color-light: #A78BFA;
  --td-brand-color-focus: #F0ABFC;
  --td-brand-color-active: #6C5FD0;
  --td-brand-color-disabled: #C4B5FD;

  /* 功能色 */
  --td-success-color: #34D399;
  --td-warning-color: #FBBF24;
  --td-error-color: #F87171;
  --td-info-color: #60A5FA;

  /* 背景色 */
  --td-bg-color-page: #FBF8FF;
  --td-bg-color-container: #FFFFFF;
  --td-bg-color-secondarycontainer: #F5F0FF;

  /* 文字色 */
  --td-text-color-primary: #1A1A2E;
  --td-text-color-secondary: #6B7280;
  --td-text-color-placeholder: #9CA3AF;

  /* 圆角 */
  --td-radius-default: 16rpx;
  --td-radius-large: 24rpx;
  --td-radius-round: 999rpx;

  /* 页面背景 */
  background-color: #FBF8FF;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.6;
}

/* ========== 通用工具类 ========== */

/* 卡片容器 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 111, 224, 0.06);
}

.card-sm {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(124, 111, 224, 0.04);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, #7C6FE0 0%, #A78BFA 50%, #F0ABFC 100%);
}

.gradient-warm {
  background: linear-gradient(135deg, #FBF8FF 0%, #F5F0FF 100%);
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A2E;
  margin-bottom: 16rpx;
}

.text-secondary {
  font-size: 26rpx;
  color: #6B7280;
}

.text-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* Flex 布局工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 32rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.mb-lg { margin-bottom: 32rpx; }
.ml-sm { margin-left: 16rpx; }
.mr-sm { margin-right: 16rpx; }
.px-md { padding-left: 24rpx; padding-right: 24rpx; }
.py-md { padding-top: 24rpx; padding-bottom: 24rpx; }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #F0EBFF;
  margin: 24rpx 0;
}

/* 标签/徽章 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: #F0EBFF;
  color: #7C6FE0;
}

.tag-success {
  background: #D1FAE5;
  color: #059669;
}

.tag-warning {
  background: #FEF3C7;
  color: #D97706;
}

.tag-error {
  background: #FEE2E2;
  color: #DC2626;
}

.tag-info {
  background: #DBEAFE;
  color: #2563EB;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #9CA3AF;
  margin-top: 24rpx;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  z-index: 100;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-scale {
  transition: transform 0.15s ease;
}

.animate-scale:active {
  transform: scale(0.96);
}

/* 安全区域适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
