/* pages/profile/index.wxss */
/* 我的页面样式 — Tender Bloom 温柔绽放主题 */

.page-profile {
  min-height: 100vh;
  background: var(--td-bg-color-page, #FDF8F3);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======= 进场动画 ======= */
.animate-fadein {
  opacity: 0;
  animation: fadeInUp 0.5s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ======= 宝宝信息大卡片 ======= */
.baby-profile-card {
  position: relative;
  margin: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  min-height: 220rpx;
  animation: fadeInUp 0.45s ease forwards;
}

.profile-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #C8956C 0%, #D4A97A 50%, #E8C4A0 100%);
}

/* 装饰性半透明光斑 */
.profile-orb {
  position: absolute;
  border-radius: 50%;
}

.profile-orb-1 {
  top: -40rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
}

.profile-orb-2 {
  bottom: -50rpx;
  left: 30rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.06);
}

.profile-orb-3 {
  top: 20rpx;
  right: 120rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

.profile-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 48rpx 32rpx;
}

.profile-avatar-area {
  flex-shrink: 0;
}

.profile-info-area {
  flex: 1;
  margin-left: 28rpx;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-age {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.profile-detail-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.profile-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(4px);
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
}

.profile-edit-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.profile-edit-icon:active {
  background: rgba(255, 255, 255, 0.3);
}

/* ======= 数据统计卡片 ======= */
.stats-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-card, 0 4rpx 20rpx rgba(200, 149, 108, 0.08));
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #3D2E22);
}

.stats-total-badge {
  display: inline-flex;
  align-items: center;
}

.stats-total {
  font-size: 24rpx;
  color: #C8956C;
  background: linear-gradient(135deg, #FDF8F3 0%, #F5EDE4 100%);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stats-grid-row2 {
  margin-bottom: 24rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #FDF8F3 0%, #F9F1E8 100%);
  border-radius: 16rpx;
  min-width: 0;
  transition: transform 0.2s ease;
}

.stats-item:active {
  transform: scale(0.96);
}

.stats-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stats-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.stats-count {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color, #C8956C);
  line-height: 1.2;
}

.stats-label {
  font-size: 20rpx;
  color: var(--td-text-color-secondary, #8B7B6B);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 存储空间条 */
.storage-bar-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #F5EDE4;
}

.storage-bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.storage-bar-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #8B7B6B);
}

.storage-bar-value {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
}

.storage-bar-track {
  height: 12rpx;
  background: #F5EDE4;
  border-radius: 6rpx;
  overflow: hidden;
}

.storage-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #C8956C 0%, #D4A97A 50%, #E8C4A0 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
  min-width: 4rpx;
}

/* ======= 区块标签 ======= */
.section-label {
  padding: 28rpx 32rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-placeholder, #B5A89C);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ======= 菜单卡片 ======= */
.menu-card {
  margin: 0 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 4rpx 20rpx rgba(200, 149, 108, 0.08));
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
  transition: background 0.15s ease;
}

.menu-item-hover {
  background: #FDF8F3;
}

.menu-item-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.menu-item-content {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--td-text-color-primary, #3D2E22);
}

.menu-item-title.danger {
  color: var(--td-error-color, #E8736C);
}

.menu-item-desc {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
  margin-top: 4rpx;
}

.menu-item-note {
  font-size: 28rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
}

.menu-divider {
  height: 1rpx;
  background: #F5EDE4;
  margin-left: 116rpx;
}

/* ======= 底部声明 ======= */
.footer-text {
  text-align: center;
  padding: 48rpx 32rpx 24rpx;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
  line-height: 1.8;
}

/* ======= 安全区 ======= */
.safe-bottom {
  height: 120rpx;
}

/* ======= 编辑弹窗 ======= */
.edit-popup {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F5EDE4;
}

.edit-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #3D2E22);
}

.edit-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5EDE4;
  transition: background 0.2s ease;
}

.edit-popup-close:active {
  background: #E8DACE;
}

.edit-popup-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

/* 头像选择 */
.form-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 32rpx;
}

.form-avatar-ring {
  position: relative;
}

.form-avatar-ring::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8956C, #D4A97A);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(200, 149, 108, 0.25);
  border: 4rpx solid #FFFFFF;
}

.form-avatar-hint {
  font-size: 24rpx;
  color: var(--td-brand-color, #C8956C);
  margin-top: 16rpx;
  font-weight: 500;
}

/* 表单组 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--td-text-color-primary, #3D2E22);
  margin-bottom: 12rpx;
}

.required {
  color: var(--td-error-color, #E8736C);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FDF8F3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3D2E22);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.25s ease, background 0.25s ease;
}

.form-input:focus {
  border-color: #C8956C;
  background: #FFFFFF;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FDF8F3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3D2E22);
  transition: background 0.2s ease;
}

.form-picker:active {
  background: #F5EDE4;
}

.form-picker .placeholder {
  color: var(--td-text-color-placeholder, #B5A89C);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #FDF8F3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3D2E22);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.25s ease, background 0.25s ease;
}

.form-textarea:focus {
  border-color: #C8956C;
  background: #FFFFFF;
}

/* 底部保存按钮 */
.edit-popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F5EDE4;
}
