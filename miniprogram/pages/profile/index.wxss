/* pages/profile/index.wxss */
/* 我的页面样式 — Tender Bloom 温柔绽放主题 */

.page-profile {
  min-height: 100vh;
  background: var(--td-bg-color-page, #fdf8f3);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======= 进场动画 ======= */
.animate-fadein {
  opacity: 0;
  animation: fadeInUp 0.5s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ======= 宝宝信息大卡片 ======= */
.baby-profile-card {
  position: relative;
  margin: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  min-height: 220rpx;
  animation: fadeInUp 0.45s ease forwards;
}

.profile-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #c8956c 0%, #d4a97a 50%, #e8c4a0 100%);
}

/* 装饰性半透明光斑 */
.profile-orb {
  position: absolute;
  border-radius: 50%;
}

.profile-orb-1 {
  top: -40rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
}

.profile-orb-2 {
  bottom: -50rpx;
  left: 30rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.06);
}

.profile-orb-3 {
  top: 20rpx;
  right: 120rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

.profile-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 48rpx 32rpx;
}

.profile-avatar-area {
  flex-shrink: 0;
}

.profile-info-area {
  flex: 1;
  margin-left: 28rpx;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-age {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.profile-detail-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.profile-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(4px);
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
}

.profile-edit-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.profile-edit-icon:active {
  background: rgba(255, 255, 255, 0.3);
}

/* ======= 数据统计卡片 ======= */
.stats-card {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-card, 0 4rpx 20rpx rgba(200, 149, 108, 0.08));
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #3d2e22);
}

.stats-total-badge {
  display: inline-flex;
  align-items: center;
}

.stats-total {
  font-size: 24rpx;
  color: #c8956c;
  background: linear-gradient(135deg, #fdf8f3 0%, #f5ede4 100%);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stats-grid-row2 {
  margin-bottom: 24rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #fdf8f3 0%, #f9f1e8 100%);
  border-radius: 16rpx;
  min-width: 0;
  transition: transform 0.2s ease;
}

.stats-item:active {
  transform: scale(0.96);
}

.stats-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stats-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.stats-count {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color, #c8956c);
  line-height: 1.2;
}

.stats-label {
  font-size: 20rpx;
  color: var(--td-text-color-secondary, #8b7b6b);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 存储空间条 */
.storage-bar-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #f5ede4;
}

.storage-bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.storage-bar-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #8b7b6b);
}

.storage-bar-value {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
}

.storage-bar-track {
  height: 12rpx;
  background: #f5ede4;
  border-radius: 6rpx;
  overflow: hidden;
}

.storage-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #c8956c 0%, #d4a97a 50%, #e8c4a0 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
  min-width: 4rpx;
}

/* ======= 区块标签 ======= */
.section-label {
  padding: 28rpx 32rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-placeholder, #b5a89c);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ======= 菜单卡片 ======= */
.menu-card {
  margin: 0 24rpx 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 4rpx 20rpx rgba(200, 149, 108, 0.08));
}

/* 提醒设置卡片 */
.menu-icon-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.setting-picker-value {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  color: var(--td-brand-color, #c8956c);
  font-weight: 500;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
  transition: background 0.15s ease;
}

.menu-item-hover {
  background: #fdf8f3;
}

.menu-item-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.menu-item-content {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--td-text-color-primary, #3d2e22);
}

.menu-item-title.danger {
  color: var(--td-error-color, #e8736c);
}

.menu-item-desc {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
  margin-top: 4rpx;
}

.sync-status-row {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.sync-status-row .menu-item-desc {
  margin-top: 0;
}

.realtime-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #52c41a;
  margin-right: 8rpx;
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%,
  100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.8);
  }
}

.menu-item-note {
  font-size: 28rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
}

.menu-divider {
  height: 1rpx;
  background: #f5ede4;
  margin-left: 116rpx;
}

/* ======= 底部声明 ======= */
.footer-text {
  text-align: center;
  padding: 48rpx 32rpx 24rpx;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
  line-height: 1.8;
}

/* ======= 安全区 ======= */
.safe-bottom {
  height: 120rpx;
}

/* ======= 编辑弹窗 ======= */
.edit-popup {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f5ede4;
}

.edit-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #3d2e22);
}

.edit-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5ede4;
  transition: background 0.2s ease;
}

.edit-popup-close:active {
  background: #e8dace;
}

.edit-popup-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

/* 头像选择 */
.form-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 32rpx;
}

.form-avatar-ring {
  position: relative;
}

.form-avatar-ring::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c8956c, #d4a97a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(200, 149, 108, 0.25);
  border: 4rpx solid #ffffff;
}

.form-avatar-hint {
  font-size: 24rpx;
  color: var(--td-brand-color, #c8956c);
  margin-top: 16rpx;
  font-weight: 500;
}

/* 表单组 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--td-text-color-primary, #3d2e22);
  margin-bottom: 12rpx;
}

.required {
  color: var(--td-error-color, #e8736c);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fdf8f3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3d2e22);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition:
    border-color 0.25s ease,
    background 0.25s ease;
}

.form-input:focus {
  border-color: #c8956c;
  background: #ffffff;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fdf8f3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3d2e22);
  transition: background 0.2s ease;
}

.form-picker:active {
  background: #f5ede4;
}

.form-picker .placeholder {
  color: var(--td-text-color-placeholder, #b5a89c);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #fdf8f3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #3d2e22);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition:
    border-color 0.25s ease,
    background 0.25s ease;
}

.form-textarea:focus {
  border-color: #c8956c;
  background: #ffffff;
}

/* 底部保存按钮 */
.edit-popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5ede4;
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .page-profile {
    background: var(--td-bg-color-page, #1a1614);
  }

  .baby-profile-card {
    box-shadow: none;
  }

  .profile-card-bg {
    background: linear-gradient(135deg, #6b5a46 0%, #8b7b5c 50%, #a89872 100%);
  }

  .stats-card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: var(--shadow-card);
  }

  .stats-title {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .stats-total {
    background: linear-gradient(135deg, #2a2420 0%, #362e28 100%);
  }

  .stats-item {
    background: linear-gradient(135deg, #2a2420 0%, #362e28 100%);
  }

  .stats-count {
    color: var(--td-brand-color, #d4a97a);
  }

  .stats-label {
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .storage-bar-section {
    border-top-color: #3d342c;
  }

  .storage-bar-label {
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .storage-bar-value {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .storage-bar-track {
    background: #362e28;
  }

  .section-label {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .menu-card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: var(--shadow-card);
  }

  .menu-item-hover {
    background: var(--td-bg-color-secondarycontainer, #362e28);
  }

  .menu-item-title {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .menu-item-desc {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .menu-item-note {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .menu-divider {
    background: #3d342c;
  }

  .setting-picker-value {
    color: var(--td-brand-color, #d4a97a);
  }

  .footer-text {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .edit-popup {
    background: var(--td-bg-color-container, #2a2420);
  }

  .edit-popup-header {
    border-bottom-color: #3d342c;
  }

  .edit-popup-title {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .edit-popup-close {
    background: #362e28;
  }

  .form-avatar-hint {
    color: var(--td-brand-color, #d4a97a);
  }

  .form-group .form-label {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .form-group .form-input,
  .form-group .form-textarea {
    background: #362e28;
    color: var(--td-text-color-primary, #ede5dc);
  }

  .form-picker {
    background: #362e28;
    color: var(--td-text-color-primary, #ede5dc);
  }

  .edit-popup-footer {
    border-top-color: #3d342c;
  }
}
