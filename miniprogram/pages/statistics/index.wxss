/* pages/statistics/index.wxss */
/* 数据统计页面样式 */

.page-statistics {
  min-height: 100vh;
  background: var(--td-bg-color-page, #fdf8f3);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #3d2e22);
}

.page-date-range {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
}

/* 趋势卡片 */
.trend-card {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(200, 149, 108, 0.06);
}

.trend-card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.trend-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trend-card-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.trend-card-info {
  flex: 1;
}

.trend-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #3d2e22);
}

.trend-card-stats {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  flex-wrap: wrap;
}

.stat-text {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #8b7b6b);
}

.stat-num {
  font-weight: 600;
  color: var(--td-brand-color, #c8956c);
}

.stat-divider {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #b5a89c);
}

/* 图表区域 */
.trend-chart-area {
  margin: 0 -8rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: 60rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeInUp 0.4s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .page-statistics {
    background: var(--td-bg-color-page, #1a1614);
  }

  .page-title {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .page-date-range {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .trend-card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.2);
  }

  .trend-card-name {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .stat-text {
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .stat-num {
    color: var(--td-brand-color, #d4a97a);
  }

  .stat-divider {
    color: var(--td-text-color-placeholder, #78695c);
  }
}
