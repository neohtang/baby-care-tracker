<!--pages/feeding/index.wxml-->
<!--喂养记录页——完整实现-->

<view class="page-feeding">
  <!-- 今日统计卡片 -->
  <view class="stats-card">
    <view class="stats-header">
      <text class="stats-title">今日喂养</text>
      <text class="stats-badge">{{todayStats.totalCount}}次</text>
    </view>
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #FCE7F3, #F5F0FF);">
          <image class="stats-icon-img" src="/assets/icons/breastfeed.svg" mode="aspectFit" />
        </view>
        <text class="stats-num">{{todayStats.breastCount}}</text>
        <text class="stats-label">母乳</text>
        <text class="stats-sub" wx:if="{{todayStats.totalBreastDuration > 0}}">{{todayStats.totalBreastDuration}}分钟</text>
      </view>
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #DBEAFE, #EDE9FE);">
          <image class="stats-icon-img" src="/assets/icons/bottle.svg" mode="aspectFit" />
        </view>
        <text class="stats-num">{{todayStats.formulaCount}}</text>
        <text class="stats-label">配方奶</text>
        <text class="stats-sub" wx:if="{{todayStats.totalFormulaAmount > 0}}">{{todayStats.totalFormulaAmount}}ml</text>
      </view>
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #FEF3C7, #FDE68A);">
          <image class="stats-icon-img" src="/assets/icons/solid-food.svg" mode="aspectFit" />
        </view>
        <text class="stats-num">{{todayStats.solidCount}}</text>
        <text class="stats-label">辅食</text>
      </view>
    </view>
  </view>

  <!-- 类型筛选 Tab -->
  <view class="tab-wrap">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{activeTab === item.value ? 'tab-active' : ''}}"
      bindtap="onTabChange"
      data-value="{{item.value}}"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{activeTab === item.value}}" class="tab-indicator"></view>
    </view>
  </view>

  <!-- 记录列表 -->
  <view wx:if="{{!isEmpty}}" class="record-list">
    <record-card
      wx:for="{{records}}"
      wx:key="id"
      recordId="{{item.id}}"
      icon="{{item.icon}}"
      iconBg="{{item.iconBg}}"
      title="{{item.typeName}}"
      timeText="{{item.timeText}}"
      detail="{{item.detail}}"
      tags="{{item.tags}}"
      showEdit="{{true}}"
      bind:edit="onEditRecord"
      bind:delete="onDeleteRecord"
    />
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{hasBaby}}" class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/bottle.svg" mode="aspectFit" />
    <text class="empty-title">暂无喂养记录</text>
    <text class="empty-desc">点击下方按钮开始记录第一次喂养</text>
  </view>
  <view wx:else class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/baby.svg" mode="aspectFit" />
    <text class="empty-title">请先添加宝宝信息</text>
    <text class="empty-desc">前往设置页添加宝宝后即可记录</text>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab-container">
    <view class="fab-btn animate-scale" bindtap="goToAdd">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>
