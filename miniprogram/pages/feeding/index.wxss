/* pages/feeding/index.wxss */
/* 喂养记录页样式 */

.page-feeding {
  padding: 24rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: #FBF8FF;
}

/* ===== 统计卡片 ===== */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(124, 111, 224, 0.08);
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.stats-badge {
  font-size: 24rpx;
  color: #7C6FE0;
  background: #F5F0FF;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.stats-icon {
  font-size: 40rpx;
}

.stats-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.stats-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A2E;
  line-height: 1;
}

.stats-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.stats-sub {
  font-size: 22rpx;
  color: #7C6FE0;
  background: #F5F0FF;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== Tab 筛选 ===== */
.tab-wrap {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 24rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #9CA3AF;
  position: relative;
  transition: color 0.3s ease;
}

.tab-active {
  color: #7C6FE0;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #7C6FE0, #A78BFA);
  border-radius: 3rpx;
}

/* ===== 记录列表 ===== */
.record-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-icon-img {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ===== FAB 按钮 ===== */
.fab-container {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  z-index: 100;
}

.fab-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6FE0, #A78BFA);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 224, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(124, 111, 224, 0.3);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}
