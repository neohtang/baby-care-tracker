/* pages/feeding/add/index.wxss */
/* 添加/编辑喂养记录样式 */

.page-add {
  padding: 24rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
  background: #fdf8f3;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d2e22;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.mode-toggle {
  font-size: 24rpx;
  color: #c8956c;
  padding: 8rpx 20rpx;
  background: #fff8f0;
  border-radius: 999rpx;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  justify-content: space-around;
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.type-active {
  border-color: #c8956c;
  background: #fff8f0;
}

.type-icon-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.type-emoji {
  font-size: 48rpx;
}

.type-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.type-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}

.type-active .type-label {
  color: #c8956c;
}

/* 侧选择 */
.side-selector {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.side-option {
  padding: 18rpx 48rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #6b7280;
  transition: all 0.3s ease;
}

.side-active {
  border-color: #c8956c;
  background: linear-gradient(135deg, #c8956c, #d4a97a);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.3);
}

/* 时长输入 */
.duration-input-wrap {
  text-align: center;
}

.duration-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.duration-value {
  font-size: 72rpx;
  font-weight: 300;
  color: #c8956c;
  font-variant-numeric: tabular-nums;
}

.duration-unit {
  font-size: 28rpx;
  color: #9ca3af;
  margin-left: 8rpx;
}

/* 奶量/辅食量 */
.amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 20rpx 0;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 300;
  color: #c8956c;
  font-variant-numeric: tabular-nums;
}

.amount-unit {
  font-size: 28rpx;
  color: #9ca3af;
  margin-left: 8rpx;
}

/* 快捷预设 */
.presets-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
  justify-content: center;
}

.preset-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 26rpx;
  color: #6b7280;
  transition: all 0.3s ease;
}

.preset-active {
  border-color: #c8956c;
  background: #fff8f0;
  color: #c8956c;
  font-weight: 500;
}

/* 时间行 */
.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-label {
  font-size: 28rpx;
  color: #3d2e22;
}

.time-value {
  font-size: 28rpx;
  color: #c8956c;
}

/* 保存按钮 */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  background: linear-gradient(135deg, #c8956c, #d4a97a);
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.3);
}

.save-btn:active {
  transform: scale(0.98);
}

/* 动画 */
.animate-scale {
  transition: transform 0.15s ease;
}
.animate-scale:active {
  transform: scale(0.95);
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .page-add {
    background: var(--td-bg-color-page, #1a1614);
  }

  .card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.2);
  }

  .section-title {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .mode-toggle {
    background: #2d2418;
    color: var(--td-brand-color, #d4a97a);
  }

  .type-active {
    border-color: var(--td-brand-color, #d4a97a);
    background: #2d2418;
  }

  .type-label {
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .type-active .type-label {
    color: var(--td-brand-color, #d4a97a);
  }

  .side-option {
    border-color: #3d342c;
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .duration-unit,
  .amount-unit {
    color: var(--td-text-color-placeholder, #78695c);
  }

  .preset-chip {
    border-color: #3d342c;
    color: var(--td-text-color-secondary, #a89a8c);
  }

  .preset-active {
    border-color: var(--td-brand-color, #d4a97a);
    background: #2d2418;
    color: var(--td-brand-color, #d4a97a);
  }

  .time-label {
    color: var(--td-text-color-primary, #ede5dc);
  }

  .time-value {
    color: var(--td-brand-color, #d4a97a);
  }

  .save-bar {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.2);
  }
}
