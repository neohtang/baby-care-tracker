/* pages/feeding/add/index.wxss */

.page-add {
  padding-bottom: 160rpx;
}

/* 类型选择器 */
.type-selector {
  justify-content: space-around;
  margin-top: 16rpx;
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  border: 2rpx solid #E5E7EB;
  min-width: 160rpx;
}

.type-active {
  border-color: #7C6FE0;
  background: #F5F0FF;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 26rpx;
  color: #6B7280;
}

.type-active .type-label {
  color: #7C6FE0;
  font-weight: 500;
}

/* 侧选择 */
.side-selector {
  justify-content: space-around;
  margin-top: 16rpx;
}

.side-option {
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  border: 2rpx solid #E5E7EB;
  font-size: 28rpx;
  color: #6B7280;
}

.side-active {
  border-color: #7C6FE0;
  background: #7C6FE0;
  color: #FFFFFF;
}

/* 计时器 */
.timer-display {
  margin: 32rpx 0;
}

.timer-text {
  font-size: 80rpx;
  font-weight: 300;
  color: #7C6FE0;
  font-variant-numeric: tabular-nums;
}

.timer-controls {
  gap: 24rpx;
}

/* 奶量 */
.amount-display {
  margin: 24rpx 0;
}

.amount-value {
  font-size: 64rpx;
  font-weight: 600;
  color: #7C6FE0;
}

.amount-unit {
  font-size: 28rpx;
  color: #9CA3AF;
  margin-left: 8rpx;
}

.amount-presets {
  justify-content: space-around;
}

/* 保存按钮 */
.save-btn-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}
