/* pages/diaper/index.wxss */
.page-diaper { padding: 24rpx; padding-bottom: 180rpx; min-height: 100vh; background: #FBF8FF; }

/* 统计卡片 */
.stats-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 24rpx rgba(124,111,224,0.08); }
.stats-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.stats-title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }
.stats-badge { font-size: 24rpx; color: #7C6FE0; background: #F5F0FF; padding: 6rpx 20rpx; border-radius: 999rpx; font-weight: 500; }
.badge-alert { color: #F87171; background: #FEE2E2; }
.stats-grid { display: flex; justify-content: space-around; }
.stats-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.stats-circle { width: 120rpx; height: 120rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.stats-circle-num { font-size: 44rpx; font-weight: 700; }
.stats-label { font-size: 24rpx; color: #9CA3AF; }

/* 快捷按钮 */
.quick-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.quick-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 12rpx;
  background: #FFFFFF; border-radius: 20rpx; padding: 28rpx 0;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); border: 2rpx solid #EDE9FE;
  transition: all 0.2s ease;
}
.quick-btn:active { border-color: #7C6FE0; background: #F5F0FF; }
.quick-btn-green { border-color: #D1FAE5; }
.quick-btn-green:active { border-color: #34D399; background: #ECFDF5; }
.quick-icon { font-size: 36rpx; }
.quick-icon-img { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.quick-text { font-size: 28rpx; color: #1A1A2E; font-weight: 500; }

/* 段落标题 */
.section-header { display: flex; align-items: center; margin-top: 32rpx; margin-bottom: 16rpx; padding: 0 8rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #1A1A2E; }

/* 记录列表 */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-icon-img { width: 80rpx; height: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-title { font-size: 32rpx; font-weight: 500; color: #6B7280; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #9CA3AF; }

/* FAB */
.fab-container { position: fixed; right: 40rpx; bottom: 120rpx; z-index: 100; }
.fab-btn { width: 112rpx; height: 112rpx; border-radius: 50%; background: linear-gradient(135deg, #7C6FE0, #A78BFA); display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 32rpx rgba(124,111,224,0.4); }
.fab-btn:active { transform: scale(0.9); }
.fab-icon { font-size: 48rpx; color: #FFFFFF; font-weight: 300; line-height: 1; }
.animate-scale { transition: transform 0.15s ease; }
.animate-scale:active { transform: scale(0.95); }
