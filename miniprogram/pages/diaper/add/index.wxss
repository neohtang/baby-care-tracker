/* pages/diaper/add/index.wxss */
.page-add { padding-bottom: 160rpx; }
.type-selector { justify-content: space-around; margin-top: 16rpx; }
.type-option { display: flex; flex-direction: column; align-items: center; padding: 24rpx 32rpx; border-radius: 20rpx; border: 2rpx solid #E5E7EB; min-width: 150rpx; }
.type-active { border-color: #7C6FE0; background: #F5F0FF; }
.type-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.type-label { font-size: 26rpx; color: #6B7280; }
.type-active .type-label { color: #7C6FE0; font-weight: 500; }
.option-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.option-chip { padding: 12rpx 28rpx; border-radius: 999rpx; border: 2rpx solid #E5E7EB; font-size: 26rpx; color: #6B7280; }
.chip-active { border-color: #7C6FE0; background: #F5F0FF; color: #7C6FE0; }
.save-btn-container { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx; background: #FFFFFF; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); }
