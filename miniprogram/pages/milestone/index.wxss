/* pages/milestone/index.wxss */
.page-milestone {
  background: #fdf8f3;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 进度摘要卡片 */
.summary-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #c8956c 0%, #d4a97a 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 40rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.25);
}
.summary-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: baseline;
  justify-content: center;
  backdrop-filter: blur(10px);
}
.summary-percent {
  font-size: 48rpx;
  font-weight: 700;
}
.summary-unit {
  font-size: 24rpx;
  font-weight: 500;
}
.summary-label {
  font-size: 24rpx;
  opacity: 0.8;
}
.summary-right {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 32rpx;
}
.summary-stat-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}
.summary-stat-num {
  font-size: 40rpx;
  font-weight: 700;
}
.summary-stat-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 2rpx;
}

/* 类别筛选 */
.category-scroll {
  margin: 0 24rpx 20rpx;
  white-space: nowrap;
}
.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}
.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}
.category-chip.active {
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.25);
}

/* 里程碑列表 */
.milestone-list {
  padding: 0 24rpx;
}
.ms-group {
  margin-bottom: 12rpx;
  position: relative;
  padding-left: 32rpx;
}
.ms-group::before {
  content: '';
  position: absolute;
  left: 7rpx;
  top: 24rpx;
  bottom: 0;
  width: 2rpx;
  background: #e5e7eb;
}
.ms-group:last-child::before {
  display: none;
}
.ms-group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  position: relative;
}
.ms-group-dot {
  position: absolute;
  left: -28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d4a97a;
  border: 3rpx solid #f0dcc8;
}
.ms-group-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #c8956c;
}
.ms-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.ms-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(200, 149, 108, 0.04);
  transition: transform 0.15s;
}
.ms-card:active {
  transform: scale(0.98);
}
.ms-card.focus {
  border-left: 4rpx solid #d4a97a;
}
.ms-card.concern {
  border-left: 4rpx solid #f87171;
  background: #fffbfb;
}
.ms-card.achieved {
  background: #f0fdf4;
}
.ms-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.ms-star {
  font-size: 36rpx;
  flex-shrink: 0;
}
.ms-star-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.ms-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3d2e22;
  flex: 1;
}
.ms-cat {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.ms-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  padding-left: 48rpx;
}
.ms-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 48rpx;
  margin-top: 8rpx;
}
.ms-achieved-date {
  font-size: 22rpx;
  color: #34d399;
  font-weight: 500;
}
.ms-concern-badge {
  font-size: 20rpx;
  color: #f87171;
  background: #fee2e2;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.ms-focus-badge {
  font-size: 20rpx;
  color: #d4a97a;
  background: #fff8f0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.ms-concern-tip {
  display: block;
  font-size: 22rpx;
  color: #f87171;
  padding-left: 48rpx;
  margin-top: 6rpx;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-icon {
  font-size: 80rpx;
  color: #d1d5db;
  line-height: 1;
}
.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 记录弹窗 */
.record-popup {
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
}
.popup-header {
  margin-bottom: 24rpx;
}
.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3d2e22;
  display: block;
}
.popup-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}
.popup-form {
  margin-bottom: 24rpx;
}
.popup-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
.popup-label {
  font-size: 28rpx;
  color: #3d2e22;
  flex-shrink: 0;
  width: 150rpx;
}
.popup-value-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.popup-value {
  font-size: 28rpx;
  color: #c8956c;
  font-weight: 500;
}
.popup-input {
  flex: 1;
}
.popup-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-save {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c8956c, #d4a97a);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.3);
}
.btn-delete {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f87171;
  font-size: 28rpx;
  border-radius: 36rpx;
  background: #fee2e2;
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .page-milestone {
    background: var(--td-bg-color-page, #1a1614);
  }
  .summary-card {
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  }
  .category-chip {
    background: var(--td-bg-color-container, #2a2420);
    color: var(--td-text-color-secondary, #a89a8c);
    box-shadow: none;
  }
  .category-chip.active {
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  }
  .ms-group::before {
    background: #3d342c;
  }
  .ms-card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  }
  .ms-card.achieved {
    background: #1e2d26;
  }
  .ms-card.concern {
    background: #2d1c1a;
  }
  .ms-name {
    color: var(--td-text-color-primary, #ede5dc);
  }
  .ms-desc {
    color: var(--td-text-color-secondary, #a89a8c);
  }
  .ms-focus-badge {
    background: #2d2418;
  }
  .empty-icon {
    color: var(--td-text-color-placeholder, #78695c);
  }
  .empty-text {
    color: var(--td-text-color-secondary, #a89a8c);
  }
  .record-popup {
    background: var(--td-bg-color-container, #2a2420);
  }
  .popup-title {
    color: var(--td-text-color-primary, #ede5dc);
  }
  .popup-desc {
    color: var(--td-text-color-secondary, #a89a8c);
  }
  .popup-label {
    color: var(--td-text-color-primary, #ede5dc);
  }
  .popup-row {
    border-bottom-color: #3d342c;
  }
  .btn-delete {
    background: #2d1c1a;
    color: #f09088;
  }
}
