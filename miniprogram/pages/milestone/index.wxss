/* pages/milestone/index.wxss */
.page-milestone { background: #FDF8F3; min-height: 100vh; padding-bottom: 60rpx; }

/* 进度摘要卡片 */
.summary-card {
  margin: 24rpx; padding: 32rpx;
  background: linear-gradient(135deg, #C8956C 0%, #D4A97A 100%);
  border-radius: 24rpx; display: flex; align-items: center; gap: 40rpx;
  color: #FFF; box-shadow: 0 8rpx 24rpx rgba(200,149,108,0.25);
}
.summary-left { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.summary-circle {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex; align-items: baseline;
  justify-content: center; backdrop-filter: blur(10px);
}
.summary-percent { font-size: 48rpx; font-weight: 700; }
.summary-unit { font-size: 24rpx; font-weight: 500; }
.summary-label { font-size: 24rpx; opacity: 0.8; }
.summary-right { flex: 1; display: flex; flex-wrap: wrap; gap: 20rpx 32rpx; }
.summary-stat-row { display: flex; flex-direction: column; align-items: center; min-width: 100rpx; }
.summary-stat-num { font-size: 40rpx; font-weight: 700; }
.summary-stat-label { font-size: 22rpx; opacity: 0.8; margin-top: 2rpx; }

/* 类别筛选 */
.category-scroll { margin: 0 24rpx 20rpx; white-space: nowrap; }
.category-list { display: inline-flex; gap: 16rpx; padding: 4rpx 0; }
.category-chip {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 12rpx 28rpx; border-radius: 999rpx;
  font-size: 26rpx; color: #6B7280; background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.category-chip.active { font-weight: 600; box-shadow: 0 4rpx 16rpx rgba(200,149,108,0.25); }

/* 里程碑列表 */
.milestone-list { padding: 0 24rpx; }
.ms-group { margin-bottom: 12rpx; position: relative; padding-left: 32rpx; }
.ms-group::before {
  content: ''; position: absolute; left: 7rpx; top: 24rpx; bottom: 0;
  width: 2rpx; background: #E5E7EB;
}
.ms-group:last-child::before { display: none; }
.ms-group-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; position: relative; }
.ms-group-dot {
  position: absolute; left: -28rpx; top: 50%; transform: translateY(-50%);
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #D4A97A; border: 3rpx solid #F0DCC8;
}
.ms-group-label { font-size: 28rpx; font-weight: 600; color: #C8956C; }
.ms-items { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 16rpx; }

.ms-card {
  background: #FFFFFF; border-radius: 20rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(200,149,108,0.04);
  transition: transform 0.15s;
}
.ms-card:active { transform: scale(0.98); }
.ms-card.focus { border-left: 4rpx solid #D4A97A; }
.ms-card.concern { border-left: 4rpx solid #F87171; background: #FFFBFB; }
.ms-card.achieved { background: #F0FDF4; }
.ms-card-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.ms-star { font-size: 36rpx; flex-shrink: 0; }
.ms-star-img { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.ms-name { font-size: 28rpx; font-weight: 500; color: #3D2E22; flex: 1; }
.ms-cat { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx; flex-shrink: 0; }
.ms-desc { font-size: 24rpx; color: #6B7280; line-height: 1.5; padding-left: 48rpx; }
.ms-footer { display: flex; align-items: center; gap: 12rpx; padding-left: 48rpx; margin-top: 8rpx; }
.ms-achieved-date { font-size: 22rpx; color: #34D399; font-weight: 500; }
.ms-concern-badge {
  font-size: 20rpx; color: #F87171; background: #FEE2E2;
  padding: 4rpx 12rpx; border-radius: 999rpx;
}
.ms-focus-badge {
  font-size: 20rpx; color: #D4A97A; background: #FFF8F0;
  padding: 4rpx 12rpx; border-radius: 999rpx;
}
.ms-concern-tip {
  display: block; font-size: 22rpx; color: #F87171; padding-left: 48rpx; margin-top: 6rpx;
  line-height: 1.5;
}

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; color: #D1D5DB; line-height: 1; }
.empty-text { font-size: 28rpx; color: #9CA3AF; }

/* 记录弹窗 */
.record-popup {
  padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #FFF; border-radius: 32rpx 32rpx 0 0;
}
.popup-header { margin-bottom: 24rpx; }
.popup-title { font-size: 34rpx; font-weight: 600; color: #3D2E22; display: block; }
.popup-desc { font-size: 24rpx; color: #6B7280; margin-top: 8rpx; display: block; line-height: 1.5; }
.popup-form { margin-bottom: 24rpx; }
.popup-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.popup-label { font-size: 28rpx; color: #3D2E22; flex-shrink: 0; width: 150rpx; }
.popup-value-row { display: flex; align-items: center; gap: 8rpx; }
.popup-value { font-size: 28rpx; color: #C8956C; font-weight: 500; }
.popup-input { flex: 1; }
.popup-btns { display: flex; flex-direction: column; gap: 16rpx; }
.btn-save {
  height: 88rpx; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #C8956C, #D4A97A); color: #FFF;
  font-size: 30rpx; font-weight: 600; border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(200,149,108,0.3);
}
.btn-delete {
  height: 72rpx; display: flex; align-items: center; justify-content: center;
  color: #F87171; font-size: 28rpx; border-radius: 36rpx; background: #FEE2E2;
}
