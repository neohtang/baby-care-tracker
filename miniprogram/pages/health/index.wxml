<!--pages/health/index.wxml-->
<!--体温/健康监测页——完整实现-->

<view class="page-health">
  <!-- 体温大卡片 -->
  <view class="temp-card">
    <view class="temp-main">
      <text class="temp-value" style="color: {{latestTempColor}};">{{latestTemp}}</text>
      <text class="temp-degree" style="color: {{latestTempColor}};">°C</text>
    </view>
    <view wx:if="{{latestTempLevelText}}" class="temp-level-badge" style="background: {{latestTempColor}}20; color: {{latestTempColor}};">
      {{latestTempLevelText}}
    </view>
    <text class="temp-hint">最近体温</text>

    <!-- 体温趋势点 -->
    <view wx:if="{{tempHistory.length > 1}}" class="temp-trend">
      <view class="trend-dots">
        <view
          wx:for="{{tempHistory}}"
          wx:key="time"
          class="trend-dot-wrap"
        >
          <view class="trend-dot" style="background: {{item.level === 'normal' ? '#34D399' : item.level === 'mild_fever' ? '#FBBF24' : item.level === 'moderate_fever' ? '#FB923C' : item.level === 'high_fever' ? '#F87171' : '#60A5FA'}};"></view>
          <text class="trend-time">{{item.timeText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="quick-btn animate-scale" bindtap="goToAdd" data-type="temperature">
      <image class="quick-icon-img" src="/assets/icons/thermometer.svg" mode="aspectFit" />
      <text class="quick-text">量体温</text>
    </view>
    <view class="quick-btn animate-scale" bindtap="goToAdd" data-type="medication">
      <image class="quick-icon-img" src="/assets/icons/medicine.svg" mode="aspectFit" />
      <text class="quick-text">记用药</text>
    </view>
    <view class="quick-btn animate-scale" bindtap="goToAdd" data-type="symptom">
      <image class="quick-icon-img" src="/assets/icons/bandage.svg" mode="aspectFit" />
      <text class="quick-text">记症状</text>
    </view>
  </view>

  <!-- Tab 筛选 -->
  <view class="tab-wrap">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{activeTab === item.value ? 'tab-active' : ''}}"
      bindtap="onTabChange"
      data-value="{{item.value}}"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{activeTab === item.value}}" class="tab-indicator"></view>
    </view>
  </view>

  <!-- 记录列表 -->
  <view wx:if="{{!isEmpty}}" class="record-list">
    <record-card
      wx:for="{{records}}"
      wx:key="id"
      recordId="{{item.id}}"
      icon="{{item.icon}}"
      iconBg="{{item.iconBg}}"
      title="{{item.typeName}}"
      timeText="{{item.timeText}}"
      detail="{{item.detail}}"
      tags="{{item.tags}}"
      alert="{{item.isAbnormal}}"
      showEdit="{{true}}"
      bind:edit="onEditRecord"
      bind:delete="onDeleteRecord"
    />
  </view>

  <view wx:elif="{{hasBaby}}" class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/thermometer.svg" mode="aspectFit" />
    <text class="empty-title">暂无健康记录</text>
    <text class="empty-desc">点击上方按钮开始记录</text>
  </view>
  <view wx:else class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/baby.svg" mode="aspectFit" />
    <text class="empty-title">请先添加宝宝信息</text>
    <text class="empty-desc">前往设置页添加宝宝后即可记录</text>
  </view>

  <!-- FAB -->
  <view class="fab-container">
    <view class="fab-btn animate-scale" bindtap="goToAdd">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>
