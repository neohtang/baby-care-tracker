<!--pages/vaccine/index.wxml-->
<view class="page-vaccine">
  <!-- 顶部 Tab -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" space-evenly>
    <t-tab-panel label="疫苗接种" value="{{0}}" />
    <t-tab-panel label="发育里程碑" value="{{1}}" />
  </t-tabs>

  <!-- ====== 疫苗接种 Tab ====== -->
  <block wx:if="{{activeTab === 0}}">
    <!-- 接种进度卡片 -->
    <view class="progress-card">
      <view class="progress-header">
        <text class="progress-title">接种进度</text>
        <text class="progress-percent">{{vaccineSummary.progress}}%</text>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{vaccineSummary.progress}}%;"></view>
      </view>
      <view class="progress-stats">
        <view class="progress-stat">
          <view class="stat-dot" style="background:#34D399;"></view>
          <text class="stat-text">已接种 {{vaccineSummary.completed}}</text>
        </view>
        <view class="progress-stat">
          <view class="stat-dot" style="background:#FBBF24;"></view>
          <text class="stat-text">待接种 {{vaccineSummary.pending}}</text>
        </view>
        <view class="progress-stat" wx:if="{{vaccineSummary.overdue > 0}}">
          <view class="stat-dot" style="background:#F87171;"></view>
          <text class="stat-text">已逾期 {{vaccineSummary.overdue}}</text>
        </view>
      </view>
    </view>

    <!-- 疫苗时间线 -->
    <view class="timeline-section">
      <view class="timeline-group" wx:for="{{vaccineGroups}}" wx:key="month">
        <view class="timeline-month">
          <view class="timeline-month-dot"></view>
          <text class="timeline-month-label">{{item.monthLabel}}</text>
        </view>
        <view class="timeline-items">
          <view
            class="vaccine-card {{vaccine.status}}"
            wx:for="{{item.vaccines}}" wx:for-item="vaccine" wx:key="*this"
            bindtap="onVaccineRecord" data-id="{{vaccine.vaccine.id}}"
          >
            <view class="vaccine-dot" style="background: {{vaccine.dotColor}};"></view>
            <view class="vaccine-info">
              <text class="vaccine-name">{{vaccine.vaccine.name}}</text>
              <text class="vaccine-desc">第{{vaccine.vaccine.doseNumber}}剂 / 共{{vaccine.vaccine.totalDoses}}剂</text>
              <text class="vaccine-disease">预防：{{vaccine.vaccine.preventDisease}}</text>
            </view>
            <view class="vaccine-status-badge" style="background: {{vaccine.statusBgColor}}; color: {{vaccine.statusColor}};">
              {{vaccine.statusLabel}}
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- ====== 发育里程碑 Tab ====== -->
  <block wx:if="{{activeTab === 1}}">
    <!-- 里程碑进度卡片 -->
    <view class="progress-card">
      <view class="progress-header">
        <text class="progress-title">发育进度</text>
        <text class="progress-percent">{{milestoneSummary.progress}}%</text>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill milestone-bar" style="width: {{milestoneSummary.progress}}%;"></view>
      </view>
      <view class="progress-stats">
        <view class="progress-stat">
          <view class="stat-dot" style="background:#34D399;"></view>
          <text class="stat-text">已达成 {{milestoneSummary.achieved}}</text>
        </view>
        <view class="progress-stat">
          <view class="stat-dot" style="background:#9CA3AF;"></view>
          <text class="stat-text">待达成 {{milestoneSummary.pending}}</text>
        </view>
        <view class="progress-stat" wx:if="{{milestoneSummary.concern > 0}}">
          <view class="stat-dot" style="background:#F87171;"></view>
          <text class="stat-text">需关注 {{milestoneSummary.concern}}</text>
        </view>
      </view>
    </view>

    <!-- 里程碑分组列表 -->
    <view class="milestone-section">
      <view class="milestone-group" wx:for="{{milestoneGroups}}" wx:key="month">
        <view class="milestone-month-header">
          <text class="milestone-month-label">{{item.monthLabel}}</text>
        </view>
        <view class="milestone-items">
          <view
            class="milestone-card {{ms.isCurrentFocus ? 'focus' : ''}} {{ms.status}}"
            wx:for="{{item.milestones}}" wx:for-item="ms" wx:key="milestoneId"
            bindtap="onMilestoneRecord" data-id="{{ms.milestone.id}}"
          >
            <text class="milestone-star" style="color: {{ms.statusColor}};">{{ms.statusIcon}}</text>
            <view class="milestone-info">
              <view class="milestone-name-row">
                <text class="milestone-name">{{ms.milestone.name}}</text>
                <view class="milestone-cat-badge" style="background: {{ms.categoryColor}}20; color: {{ms.categoryColor}};">
                  {{ms.categoryLabel}}
                </view>
              </view>
              <text class="milestone-desc">{{ms.description}}</text>
              <text wx:if="{{ms.dateText}}" class="milestone-date">{{ms.dateText}}</text>
              <text wx:if="{{ms.status === 'concern' && ms.concernTip}}" class="milestone-concern">{{ms.concernTip}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- ====== 疫苗记录弹窗 ====== -->
  <t-popup visible="{{showVaccinePopup}}" placement="bottom" bind:visible-change="closeVaccinePopup">
    <view class="record-popup" wx:if="{{selectedVaccine}}">
      <view class="popup-header">
        <text class="popup-title">{{selectedVaccine.vaccine.name}}</text>
        <text class="popup-subtitle">{{selectedVaccine.vaccine.fullName}}</text>
      </view>

      <view class="popup-info-row" wx:if="{{selectedVaccine.vaccine.description}}">
        <text class="popup-info-text">{{selectedVaccine.vaccine.description}}</text>
      </view>

      <view class="popup-form">
        <view class="popup-form-row" bindtap="onVaccineDateTap">
          <text class="popup-form-label">接种日期</text>
          <view class="popup-form-value-row">
            <text class="popup-form-value">{{vaccineForm.date}}</text>
            <t-icon name="chevron-right" size="32rpx" color="#9CA3AF" />
          </view>
        </view>
        <view class="popup-form-row">
          <text class="popup-form-label">接种机构</text>
          <t-input value="{{vaccineForm.location}}" placeholder="如：社区卫生服务中心" bind:change="onVaccineLocationChange" borderless class="popup-form-input" />
        </view>
        <view class="popup-form-row">
          <text class="popup-form-label">疫苗批号</text>
          <t-input value="{{vaccineForm.batchNumber}}" placeholder="可选" bind:change="onVaccineBatchChange" borderless class="popup-form-input" />
        </view>
        <view class="popup-form-row">
          <text class="popup-form-label">接种反应</text>
          <t-input value="{{vaccineForm.reaction}}" placeholder="如：轻微发红" bind:change="onVaccineReactionChange" borderless class="popup-form-input" />
        </view>
        <view class="popup-form-row">
          <text class="popup-form-label">备注</text>
          <t-input value="{{vaccineForm.note}}" placeholder="可选" bind:change="onVaccineNoteChange" borderless class="popup-form-input" />
        </view>
      </view>

      <view class="popup-actions">
        <view class="popup-save-btn" bindtap="saveVaccineRecord">
          {{selectedVaccine.record ? '更新记录' : '记录接种'}}
        </view>
        <view wx:if="{{selectedVaccine.record}}" class="popup-delete-btn" bindtap="deleteVaccineRecord">
          删除记录
        </view>
      </view>
    </view>
  </t-popup>

  <!-- ====== 里程碑记录弹窗 ====== -->
  <t-popup visible="{{showMilestonePopup}}" placement="bottom" bind:visible-change="closeMilestonePopup">
    <view class="record-popup" wx:if="{{selectedMilestone}}">
      <view class="popup-header">
        <text class="popup-title">{{selectedMilestone.milestone.name}}</text>
        <text class="popup-subtitle">{{selectedMilestone.description}}</text>
      </view>

      <view class="popup-form">
        <view class="popup-form-row" bindtap="onMilestoneDateTap">
          <text class="popup-form-label">达成日期</text>
          <view class="popup-form-value-row">
            <text class="popup-form-value">{{milestoneForm.achievedDate}}</text>
            <t-icon name="chevron-right" size="32rpx" color="#9CA3AF" />
          </view>
        </view>
        <view class="popup-form-row">
          <text class="popup-form-label">备注</text>
          <t-input value="{{milestoneForm.note}}" placeholder="记录宝宝的表现" bind:change="onMilestoneNoteChange" borderless class="popup-form-input" />
        </view>
      </view>

      <view class="popup-actions">
        <view class="popup-save-btn" bindtap="saveMilestoneRecord">
          {{selectedMilestone.record ? '更新记录' : '记录达成'}}
        </view>
        <view wx:if="{{selectedMilestone.record}}" class="popup-delete-btn" bindtap="deleteMilestoneRecord">
          删除记录
        </view>
      </view>
    </view>
  </t-popup>

  <!-- 日期选择器们 -->
  <t-date-time-picker
    title="选择接种日期"
    visible="{{showVaccineDatePicker}}"
    mode="date" value="{{vaccineForm.date}}" format="YYYY-MM-DD"
    bind:confirm="onVaccineDateConfirm" bind:cancel="onVaccineDateCancel"
  />
  <t-date-time-picker
    title="选择达成日期"
    visible="{{showMilestoneDatePicker}}"
    mode="date" value="{{milestoneForm.achievedDate}}" format="YYYY-MM-DD"
    bind:confirm="onMilestoneDateConfirm" bind:cancel="onMilestoneDateCancel"
  />
</view>
