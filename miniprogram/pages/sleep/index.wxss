/* pages/sleep/index.wxss */
/* 睡眠记录页样式 */

.page-sleep {
  padding: 24rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: #FBF8FF;
}

/* ===== 统计卡片 ===== */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(124, 111, 224, 0.08);
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.stats-title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }

.stats-badge {
  font-size: 24rpx; color: #7C6FE0; background: #F5F0FF;
  padding: 6rpx 20rpx; border-radius: 999rpx; font-weight: 500;
}

.stats-grid { display: flex; justify-content: space-around; }

.stats-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }

.stats-icon-wrap {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; margin-bottom: 8rpx;
}

.stats-icon { font-size: 40rpx; }
.stats-icon-img { width: 40rpx; height: 40rpx; }
.stats-num { font-size: 40rpx; font-weight: 600; color: #1A1A2E; line-height: 1; }
.primary-text { color: #7C6FE0; }
.stats-label { font-size: 24rpx; color: #9CA3AF; }
.stats-sub { font-size: 22rpx; color: #7C6FE0; background: #F5F0FF; padding: 2rpx 12rpx; border-radius: 8rpx; }

/* ===== 睡眠控制器 ===== */
.sleep-controller {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  justify-content: center;
}

.sleep-toggle-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.sleep-circle {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #DBEAFE, #EDE9FE);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.5s ease;
}

.sleep-circle.sleeping {
  background: linear-gradient(135deg, #312E81, #4C1D95);
  box-shadow: 0 0 60rpx rgba(124, 111, 224, 0.5);
}

.sleep-ring {
  position: absolute;
  inset: -12rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(124, 111, 224, 0.2);
}

.ring-pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.08); opacity: 1; }
}

.sleep-emoji { font-size: 80rpx; z-index: 1; }
.sleep-emoji-img { width: 80rpx; height: 80rpx; z-index: 1; }

.sleep-action-text {
  font-size: 28rpx; color: #6B7280; font-weight: 500;
}

.sleep-duration-text {
  font-size: 32rpx; color: #7C6FE0; font-weight: 600;
}

/* ===== 段落标题 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title { font-size: 30rpx; font-weight: 600; color: #1A1A2E; }

/* ===== 记录列表 ===== */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }

/* ===== 空状态 ===== */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-icon-img { width: 80rpx; height: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-title { font-size: 32rpx; font-weight: 500; color: #6B7280; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #9CA3AF; }

/* ===== FAB ===== */
.fab-container { position: fixed; right: 40rpx; bottom: 120rpx; z-index: 100; }
.fab-btn {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7C6FE0, #A78BFA);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(124, 111, 224, 0.4);
}
.fab-btn:active { transform: scale(0.9); }
.fab-icon { font-size: 48rpx; color: #FFFFFF; font-weight: 300; line-height: 1; }
