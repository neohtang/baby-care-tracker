/* pages/sleep/index.wxss */
.page-sleep { padding-bottom: 160rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 44rpx; font-weight: 600; color: #1A1A2E; }
.primary-text { color: #7C6FE0; }

.sleep-toggle { display: flex; flex-direction: column; align-items: center; padding: 32rpx; }
.sleep-toggle-circle {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: linear-gradient(135deg, #DBEAFE, #EDE9FE);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s ease;
}
.sleep-toggle-circle.sleeping {
  background: linear-gradient(135deg, #312E81, #4C1D95);
  box-shadow: 0 0 40rpx rgba(124, 111, 224, 0.4);
}
.sleep-toggle-icon { font-size: 64rpx; }
.sleep-toggle-text { font-size: 28rpx; color: #6B7280; }

.record-type-icon {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 36rpx;
}
.record-title { font-size: 28rpx; font-weight: 500; color: #1A1A2E; }
