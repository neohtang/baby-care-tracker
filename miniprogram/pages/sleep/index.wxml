<!--pages/sleep/index.wxml-->
<!--睡眠记录页——完整实现-->

<view class="page-sleep">
  <!-- 今日统计 -->
  <view class="stats-card">
    <view class="stats-header">
      <text class="stats-title">今日睡眠</text>
      <text class="stats-badge">{{todayStats.totalDurationText}}h</text>
    </view>
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #DBEAFE, #C7D2FE);">
          <image class="stats-icon-img" src="/assets/icons/timer.svg" mode="aspectFit" />
        </view>
        <text class="stats-num primary-text">{{todayStats.totalDurationText}}</text>
        <text class="stats-label">总时长(h)</text>
      </view>
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #FEF3C7, #FDE68A);">
          <image class="stats-icon-img" src="/assets/icons/sun.svg" mode="aspectFit" />
        </view>
        <text class="stats-num">{{todayStats.napCount}}</text>
        <text class="stats-label">小睡次数</text>
        <text class="stats-sub" wx:if="{{todayStats.napDuration > 0}}">{{todayStats.napDurationText}}h</text>
      </view>
      <view class="stats-item">
        <view class="stats-icon-wrap" style="background: linear-gradient(135deg, #312E81, #4C1D95);">
          <image class="stats-icon-img" src="/assets/icons/moon.svg" mode="aspectFit" />
        </view>
        <text class="stats-num">{{todayStats.nightDurationText}}</text>
        <text class="stats-label">夜间(h)</text>
      </view>
    </view>
  </view>

  <!-- 一键睡眠控制器 -->
  <view class="sleep-controller">
    <view class="sleep-toggle-area animate-scale" bindtap="toggleSleep">
      <view class="sleep-circle {{isSleeping ? 'sleeping' : ''}}">
        <view class="sleep-ring {{isSleeping ? 'ring-pulse' : ''}}"></view>
        <image class="sleep-emoji-img" src="{{isSleeping ? '/assets/icons/moon.svg' : '/assets/icons/sun.svg'}}" mode="aspectFit" />
      </view>
      <text class="sleep-action-text">{{isSleeping ? '点击结束睡眠' : '点击开始睡眠'}}</text>
      <text wx:if="{{isSleeping && sleepDurationText}}" class="sleep-duration-text">已睡 {{sleepDurationText}}</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="section-header">
    <text class="section-title">睡眠记录</text>
  </view>

  <view wx:if="{{!isEmpty}}" class="record-list">
    <record-card
      wx:for="{{records}}"
      wx:key="id"
      recordId="{{item.id}}"
      icon="{{item.icon}}"
      iconBg="{{item.iconBg}}"
      title="{{item.typeName}}"
      timeText="{{item.durationText}}"
      detail="{{item.startTimeText}} - {{item.endTimeText}}"
      bind:delete="onDeleteRecord"
    />
  </view>

  <view wx:elif="{{hasBaby}}" class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/sleep.svg" mode="aspectFit" />
    <text class="empty-title">暂无睡眠记录</text>
    <text class="empty-desc">点击上方按钮开始记录睡眠</text>
  </view>
  <view wx:else class="empty-state">
    <image class="empty-icon-img" src="/assets/icons/baby.svg" mode="aspectFit" />
    <text class="empty-title">请先添加宝宝信息</text>
    <text class="empty-desc">前往设置页添加宝宝后即可记录</text>
  </view>

  <!-- FAB -->
  <view class="fab-container">
    <view class="fab-btn animate-scale" bindtap="goToAdd">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>
