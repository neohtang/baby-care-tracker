/* pages/sleep/add/index.wxss */
.page-add {
  padding: 24rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
  background: #fdf8f3;
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d2e22;
  margin-bottom: 20rpx;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  justify-content: space-around;
}
.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}
.type-active {
  border-color: #c8956c;
  background: #fff8f0;
}
.type-icon-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.type-emoji {
  font-size: 48rpx;
}
.type-icon-img {
  width: 48rpx;
  height: 48rpx;
}
.type-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}
.type-active .type-label {
  color: #c8956c;
}

/* 时间选择行 */
.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.time-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.time-icon {
  font-size: 36rpx;
}
.time-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.time-label {
  font-size: 28rpx;
  color: #3d2e22;
}
.time-value {
  font-size: 28rpx;
  color: #c8956c;
  font-weight: 500;
}
.time-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 8rpx 0;
}

/* 时长标记 */
.duration-badge {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #fff8f0, #faeee0);
  border-radius: 16rpx;
}
.duration-text {
  font-size: 30rpx;
  color: #c8956c;
  font-weight: 600;
}

/* 质量评分 */
.quality-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}
.quality-star {
  font-size: 56rpx;
}
.star-active {
  color: #fbbf24;
}
.star-inactive {
  color: #e5e7eb;
}
.star-img {
  width: 56rpx;
  height: 56rpx;
}

/* 保存 */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}
.save-btn {
  background: linear-gradient(135deg, #c8956c, #d4a97a);
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.3);
}
.save-btn:active {
  transform: scale(0.98);
}
.animate-scale {
  transition: transform 0.15s ease;
}
.animate-scale:active {
  transform: scale(0.95);
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .page-add {
    background: var(--td-bg-color-page, #1a1614);
  }
  .card {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.2);
  }
  .section-title {
    color: var(--td-text-color-primary, #ede5dc);
  }
  .type-active {
    border-color: var(--td-brand-color, #d4a97a);
    background: #2d2418;
  }
  .type-label {
    color: var(--td-text-color-secondary, #a89a8c);
  }
  .type-active .type-label {
    color: var(--td-brand-color, #d4a97a);
  }
  .time-label {
    color: var(--td-text-color-primary, #ede5dc);
  }
  .time-value {
    color: var(--td-brand-color, #d4a97a);
  }
  .time-divider {
    background: #3d342c;
  }
  .duration-badge {
    background: linear-gradient(135deg, #2d2418, #362e20);
  }
  .star-inactive {
    color: #3d342c;
  }
  .save-bar {
    background: var(--td-bg-color-container, #2a2420);
    box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.2);
  }
}
