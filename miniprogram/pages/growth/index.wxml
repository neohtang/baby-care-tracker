<!--pages/growth/index.wxml-->
<view class="page-growth">
  <!-- 最新数据卡片 -->
  <view class="latest-card">
    <view class="latest-header">
      <text class="latest-title">最新测量</text>
      <text class="latest-date" wx:if="{{latest.hasData}}">{{latest.dateText}}</text>
    </view>
    <view class="latest-metrics">
      <view class="metric-item">
        <view class="metric-icon-wrap" style="background: linear-gradient(135deg, #7C6FE0, #A78BFA);">
          <image class="metric-icon-img" src="/assets/icons/scale.svg" mode="aspectFit" />
        </view>
        <text class="metric-value">{{latest.weight}}</text>
        <text class="metric-unit">kg</text>
        <text class="metric-label">体重</text>
        <text wx:if="{{latest.weightPercentile}}" class="metric-percentile">{{latest.weightPercentile}}</text>
      </view>
      <view class="metric-divider"></view>
      <view class="metric-item">
        <view class="metric-icon-wrap" style="background: linear-gradient(135deg, #A78BFA, #C4B5FD);">
          <image class="metric-icon-img" src="/assets/icons/ruler.svg" mode="aspectFit" />
        </view>
        <text class="metric-value">{{latest.height}}</text>
        <text class="metric-unit">cm</text>
        <text class="metric-label">身长</text>
        <text wx:if="{{latest.heightPercentile}}" class="metric-percentile">{{latest.heightPercentile}}</text>
      </view>
      <view class="metric-divider"></view>
      <view class="metric-item">
        <view class="metric-icon-wrap" style="background: linear-gradient(135deg, #F0ABFC, #E879F9);">
          <image class="metric-icon-img" src="/assets/icons/brain.svg" mode="aspectFit" />
        </view>
        <text class="metric-value">{{latest.headCircumference}}</text>
        <text class="metric-unit">cm</text>
        <text class="metric-label">头围</text>
        <text wx:if="{{latest.headPercentile}}" class="metric-percentile">{{latest.headPercentile}}</text>
      </view>
    </view>
  </view>

  <!-- 生长曲线图 -->
  <view class="chart-card">
    <view class="chart-header">
      <text class="chart-title">生长曲线</text>
      <view class="chart-tabs">
        <view
          wx:for="{{chartTabs}}" wx:key="value"
          class="chart-tab {{chartType === item.value ? 'tab-active' : ''}}"
          bindtap="onChartTypeChange" data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>
    <view class="chart-body">
      <growth-chart
        type="{{chartType}}"
        gender="{{gender}}"
        whoData="{{whoData}}"
        babyData="{{babyChartData}}"
      />
    </view>
    <view wx:if="{{!hasChartData}}" class="chart-empty-hint">
      <text>添加测量记录后将在此显示生长曲线</text>
    </view>
  </view>

  <!-- 测量记录列表 -->
  <view class="section-header">
    <text class="section-title">测量记录</text>
    <text class="section-count" wx:if="{{records.length > 0}}">共{{records.length}}条</text>
  </view>

  <view wx:if="{{records.length > 0}}" class="record-list">
    <view
      class="growth-record-card"
      wx:for="{{records}}" wx:key="id"
      bindtap="onEditRecord" data-id="{{item.id}}"
    >
      <view class="record-date-col">
        <text class="record-date">{{item.dateText}}</text>
        <text class="record-age">{{item.ageText}}</text>
      </view>
      <view class="record-data-col">
        <view class="record-tag" wx:if="{{item.hasWeight}}">
          <text class="tag-dot" style="background:#7C6FE0;"></text>
          <text class="tag-text">{{item.weight}}kg</text>
        </view>
        <view class="record-tag" wx:if="{{item.hasHeight}}">
          <text class="tag-dot" style="background:#A78BFA;"></text>
          <text class="tag-text">{{item.height}}cm</text>
        </view>
        <view class="record-tag" wx:if="{{item.hasHead}}">
          <text class="tag-dot" style="background:#F0ABFC;"></text>
          <text class="tag-text">{{item.headCircumference}}cm</text>
        </view>
      </view>
      <view class="record-actions" catchtap="onDeleteRecord" data-id="{{item.id}}">
        <t-icon name="delete" size="36rpx" color="#9CA3AF" />
      </view>
    </view>
  </view>
  <view wx:else class="empty-state">
    <image class="empty-state-icon-img" src="/assets/icons/chart.svg" mode="aspectFit" />
    <text class="empty-state-text">暂无测量记录</text>
    <text class="empty-state-hint">点击下方按钮添加第一条记录</text>
  </view>

  <!-- 添加记录弹窗 -->
  <t-popup visible="{{showAddPanel}}" placement="bottom" bind:visible-change="toggleAddPanel">
    <view class="add-panel">
      <view class="panel-header">
        <text class="panel-title">{{isEdit ? '编辑测量记录' : '添加测量记录'}}</text>
      </view>

      <view class="form-row" bindtap="openDatePicker">
        <text class="form-label">测量日期</text>
        <view class="form-value-row">
          <text class="form-value">{{newRecord.date}}</text>
          <t-icon name="chevron-right" size="32rpx" color="#9CA3AF" />
        </view>
      </view>

      <view class="form-group">
        <view class="form-input-row">
          <text class="form-label-inline">体重</text>
          <t-input
            type="digit" value="{{newRecord.weight}}" placeholder="如 5.2"
            bind:change="onWeightChange" class="form-input"
            suffix="kg" borderless
          />
        </view>
        <view class="form-input-row">
          <text class="form-label-inline">身长</text>
          <t-input
            type="digit" value="{{newRecord.height}}" placeholder="如 58.5"
            bind:change="onHeightChange" class="form-input"
            suffix="cm" borderless
          />
        </view>
        <view class="form-input-row">
          <text class="form-label-inline">头围</text>
          <t-input
            type="digit" value="{{newRecord.headCircumference}}" placeholder="如 38.0"
            bind:change="onHeadChange" class="form-input"
            suffix="cm" borderless
          />
        </view>
      </view>

      <view class="form-input-row">
        <text class="form-label-inline">备注</text>
        <t-input
          value="{{newRecord.note}}" placeholder="可选备注"
          bind:change="onNoteChange" class="form-input" borderless
        />
      </view>

      <view class="form-hint">至少填写一项测量数据</view>

      <view class="save-btn" bindtap="onSave">保存</view>
    </view>
  </t-popup>

  <!-- 日期选择器 -->
  <t-date-time-picker
    title="选择测量日期"
    visible="{{showDatePicker}}"
    mode="date"
    value="{{newRecord.date}}"
    format="YYYY-MM-DD"
    bind:confirm="onDateChange"
    bind:cancel="onDatePickerCancel"
  />

  <!-- FAB 按钮 -->
  <view class="fab-wrap">
    <view class="fab-btn" bindtap="toggleAddPanel">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>
