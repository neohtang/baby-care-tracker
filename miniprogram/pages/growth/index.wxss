/* pages/growth/index.wxss */
.page-growth { padding: 24rpx; padding-bottom: 180rpx; background: #FBF8FF; min-height: 100vh; }

/* 最新数据卡片 */
.latest-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 16rpx rgba(124,111,224,0.06); }
.latest-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.latest-title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }
.latest-date { font-size: 24rpx; color: #9CA3AF; }
.latest-metrics { display: flex; align-items: flex-start; }
.metric-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.metric-icon-wrap { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 8rpx; }
.metric-icon-text { font-size: 28rpx; }
.metric-icon-img { width: 28rpx; height: 28rpx; }
.metric-value { font-size: 48rpx; font-weight: 700; color: #1A1A2E; line-height: 1.1; }
.metric-unit { font-size: 22rpx; color: #9CA3AF; margin-top: -4rpx; }
.metric-label { font-size: 24rpx; color: #6B7280; }
.metric-percentile { font-size: 20rpx; color: #A78BFA; margin-top: 4rpx; text-align: center; }
.metric-divider { width: 1rpx; height: 80rpx; background: #F3F4F6; margin-top: 40rpx; }

/* 曲线图卡片 */
.chart-card { background: #FFFFFF; border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 16rpx rgba(124,111,224,0.06); position: relative; }
.chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.chart-title { font-size: 30rpx; font-weight: 600; color: #1A1A2E; }
.chart-tabs { display: flex; gap: 12rpx; }
.chart-tab { padding: 8rpx 24rpx; border-radius: 999rpx; font-size: 24rpx; color: #6B7280; background: #F5F0FF; transition: all 0.2s; }
.tab-active { background: linear-gradient(135deg, #7C6FE0, #A78BFA); color: #FFF; font-weight: 500; }
.chart-body { position: relative; }
.chart-empty-hint { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 24rpx; color: #9CA3AF; text-align: center; pointer-events: none; }

/* 段落标题 */
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 8rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #1A1A2E; }
.section-count { font-size: 24rpx; color: #9CA3AF; }

/* 记录列表 */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }
.growth-record-card {
  background: #FFFFFF; border-radius: 20rpx; padding: 24rpx 28rpx;
  display: flex; align-items: center; gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(124,111,224,0.04);
  transition: transform 0.15s;
}
.growth-record-card:active { transform: scale(0.98); }
.record-date-col { display: flex; flex-direction: column; gap: 4rpx; min-width: 160rpx; }
.record-date { font-size: 26rpx; font-weight: 500; color: #1A1A2E; }
.record-age { font-size: 22rpx; color: #A78BFA; }
.record-data-col { flex: 1; display: flex; flex-wrap: wrap; gap: 12rpx; }
.record-tag {
  display: flex; align-items: center; gap: 8rpx;
  background: #F5F0FF; border-radius: 999rpx; padding: 6rpx 16rpx;
}
.tag-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.tag-text { font-size: 24rpx; color: #1A1A2E; font-weight: 500; }
.record-actions { flex-shrink: 0; padding: 8rpx; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 12rpx; }
.empty-state-icon { font-size: 80rpx; }
.empty-state-icon-img { width: 80rpx; height: 80rpx; opacity: 0.6; }
.empty-state-text { font-size: 28rpx; color: #6B7280; }
.empty-state-hint { font-size: 24rpx; color: #9CA3AF; }

/* 添加面板 */
.add-panel { padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); background: #FFF; border-radius: 32rpx 32rpx 0 0; }
.panel-header { text-align: center; margin-bottom: 32rpx; }
.panel-title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }
.form-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.form-label { font-size: 28rpx; color: #1A1A2E; }
.form-value-row { display: flex; align-items: center; gap: 8rpx; }
.form-value { font-size: 28rpx; color: #7C6FE0; font-weight: 500; }
.form-group { margin-top: 16rpx; }
.form-input-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.form-label-inline { font-size: 28rpx; color: #1A1A2E; width: 100rpx; flex-shrink: 0; }
.form-input { flex: 1; }
.form-hint { font-size: 22rpx; color: #9CA3AF; text-align: center; margin: 20rpx 0; }
.save-btn {
  width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #7C6FE0, #A78BFA); color: #FFF;
  font-size: 30rpx; font-weight: 600; border-radius: 44rpx; margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(124,111,224,0.3);
}

/* FAB */
.fab-wrap { position: fixed; right: 40rpx; bottom: 60rpx; z-index: 100; }
.fab-btn {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7C6FE0, #A78BFA);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(124,111,224,0.35);
  transition: transform 0.2s;
}
.fab-btn:active { transform: scale(0.9); }
.fab-icon { font-size: 48rpx; color: #FFF; font-weight: 300; margin-top: -4rpx; }
