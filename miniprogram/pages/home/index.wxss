/* pages/home/index.wxss */
/* 首页仪表盘样式 */

.page-home {
  padding-bottom: 120rpx;
}

/* 宝宝信息卡片 */
.baby-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
}

.baby-avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.baby-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.baby-age {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 今日数据摘要 */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  text-align: center;
}

.summary-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.summary-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* 快捷操作 */
.quick-actions {
  justify-content: space-around;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-btn-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.quick-btn-text {
  font-size: 24rpx;
  color: #6B7280;
}

/* 时间线 */
.timeline-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  position: relative;
  padding-left: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: 12rpx;
  top: 36rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 19rpx;
  top: 56rpx;
  width: 2rpx;
  height: calc(100% - 20rpx);
  background: #E5E7EB;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-content {
  padding: 4rpx 0;
}

.timeline-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
}
