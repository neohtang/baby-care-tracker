/* pages/home/index.wxss */
/* 首页仪表盘 — Tender Bloom 主题 */

.page-home {
  min-height: 100vh;
  background: var(--td-bg-color-page, #FDF8F3);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======= 宝宝信息卡片 ======= */
.baby-card {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  min-height: 180rpx;
}

.baby-card-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #C8956C 0%, #D4A97A 40%, #E8C4A0 100%);
}

/* 装饰性光斑 */
.baby-card-orb {
  position: absolute;
  border-radius: 50%;
}

.baby-card-orb-1 {
  top: -60rpx; right: -40rpx;
  width: 240rpx; height: 240rpx;
  background: rgba(255, 255, 255, 0.1);
}

.baby-card-orb-2 {
  bottom: -30rpx; left: 40rpx;
  width: 160rpx; height: 160rpx;
  background: rgba(255, 255, 255, 0.07);
}

.baby-card-orb-3 {
  top: 20rpx; right: 120rpx;
  width: 80rpx; height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
}

.baby-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 32rpx;
}

.baby-info-block {
  flex: 1;
  margin-left: 24rpx;
}

.baby-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.baby-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.baby-gender-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
}

.baby-gender-tag.male {
  background: rgba(124, 175, 212, 0.5);
}

.baby-gender-tag.female {
  background: rgba(245, 165, 184, 0.5);
}

.baby-age {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.baby-card-arrow {
  flex-shrink: 0;
  opacity: 0.6;
}

/* ======= 区块标题 ======= */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #3D2E22);
  letter-spacing: 0.5rpx;
}

.section-date {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
}

.section-count-badge {
  background: #FFF5ED;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.section-count {
  font-size: 24rpx;
  color: var(--td-brand-color, #C8956C);
  font-weight: 500;
}

/* ======= 今日数据摘要 ======= */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
}

.summary-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: var(--shadow-card-sm, 0 2rpx 12rpx rgba(200, 149, 108, 0.06));
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.4s ease forwards;
}

.summary-card:active {
  transform: scale(0.97);
}

.summary-card.alert {
  border: 2rpx solid rgba(232, 115, 108, 0.3);
}

.summary-card.alert::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 6rpx; height: 100%;
  background: var(--color-coral, #E8736C);
  border-radius: 3rpx;
}

.summary-card:nth-child(1) { animation-delay: 0.05s; }
.summary-card:nth-child(2) { animation-delay: 0.1s; }
.summary-card:nth-child(3) { animation-delay: 0.15s; }
.summary-card:nth-child(4) { animation-delay: 0.2s; }

.summary-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.summary-data {
  display: flex;
  flex-direction: column;
}

.summary-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.summary-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #3D2E22);
  line-height: 1.1;
}

.summary-unit {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
  font-weight: 500;
}

.summary-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #8B7B6B);
  margin-top: 2rpx;
}

.summary-detail-wrapper {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  max-width: 100%;
}

.summary-detail {
  font-size: 22rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ======= 快捷操作（2x3 网格） ======= */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx 0;
  padding: 0 24rpx;
  justify-items: center;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: transform 0.15s ease;
  animation: fadeInUp 0.4s ease forwards;
}

.quick-btn-hover {
  transform: scale(0.92);
}

.quick-btn:nth-child(1) { animation-delay: 0.05s; }
.quick-btn:nth-child(2) { animation-delay: 0.1s; }
.quick-btn:nth-child(3) { animation-delay: 0.15s; }
.quick-btn:nth-child(4) { animation-delay: 0.2s; }
.quick-btn:nth-child(5) { animation-delay: 0.25s; }
.quick-btn:nth-child(6) { animation-delay: 0.3s; }

.quick-btn-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.08);
  transition: box-shadow 0.2s ease;
}

.quick-btn-svg {
  width: 48rpx;
  height: 48rpx;
}

.quick-btn-text {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #8B7B6B);
  font-weight: 500;
}

/* ======= 时间线区域 ======= */
.timeline-section {
  padding: 0 24rpx;
  min-height: 200rpx;
}

/* ======= 空状态 ======= */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon-img {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: var(--td-text-color-secondary, #8B7B6B);
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #B5A89C);
  margin-top: 12rpx;
}

/* ======= 底部安全区 ======= */
.safe-bottom {
  height: 120rpx;
}

/* ======= 动画 ======= */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
