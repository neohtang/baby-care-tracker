<!--pages/home/index.wxml-->
<!--首页仪表盘 — Tender Bloom 主题-->

<page-meta page-style="{{pageStyle}}" />
<view class="page-home">
  <!-- 宝宝信息卡片 -->
  <view class="baby-card animate-fade-in" bindtap="goToBabyProfile">
    <view class="baby-card-bg">
      <view class="baby-card-orb baby-card-orb-1"></view>
      <view class="baby-card-orb baby-card-orb-2"></view>
      <view class="baby-card-orb baby-card-orb-3"></view>
    </view>
    <view class="baby-card-content">
      <baby-avatar
        avatarUrl="{{babyAvatarUrl}}"
        name="{{babyName}}"
        ageText="{{babyAgeText}}"
        size="large"
        showAge="{{false}}"
        gender="{{babyGender}}"
      />
      <view class="baby-info-block">
        <view class="baby-name-row">
          <text class="baby-name">{{babyName || '添加宝宝信息'}}</text>
          <view wx:if="{{babyGenderText}}" class="baby-gender-tag {{babyGender}}">
            <text>{{babyGenderText}}</text>
          </view>
        </view>
        <text class="baby-age">{{babyAgeText}}</text>
      </view>
      <view class="baby-card-arrow">
        <t-icon name="chevron-right" size="40rpx" color="rgba(255,255,255,0.6)" />
      </view>
    </view>
  </view>

  <!-- 今日数据摘要 -->
  <view class="section-header">
    <text class="section-title">今日概览</text>
    <view class="section-right-actions">
      <view class="trend-entry" bindtap="goToAiAdvisor" hover-class="trend-entry-hover">
        <text class="trend-entry-text">AI助手</text>
        <t-icon name="chevron-right" size="28rpx" color="#C8956C" />
      </view>
      <view class="trend-entry" bindtap="goToReport" hover-class="trend-entry-hover">
        <text class="trend-entry-text">成长报告</text>
        <t-icon name="chevron-right" size="28rpx" color="#C8956C" />
      </view>
      <view class="trend-entry" bindtap="goToStatistics" hover-class="trend-entry-hover">
        <text class="trend-entry-text">趋势分析</text>
        <t-icon name="chevron-right" size="28rpx" color="#C8956C" />
      </view>
    </view>
  </view>

  <view class="summary-grid">
    <view
      class="summary-card {{item.alert ? 'alert' : ''}}"
      wx:for="{{summaryItems}}"
      wx:key="label"
      data-index="{{index}}"
      bindtap="onSummaryTap"
    >
      <view class="summary-icon-wrapper" style="background: {{item.iconBg}};">
        <image class="summary-icon-img" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <view class="summary-data">
        <view class="summary-value-row">
          <text class="summary-value">{{item.value}}</text>
          <text class="summary-unit">{{item.unit}}</text>
        </view>
        <text class="summary-label">{{item.label}}</text>
      </view>
      <view
        class="summary-detail-wrapper"
        style="background: {{item.detailBg || 'var(--td-bg-color-secondarycontainer)'}};"
      >
        <text class="summary-detail" style="color: {{item.detailColor || 'var(--td-brand-color)'}};"
          >{{item.detail}}</text
        >
      </view>
    </view>
  </view>

  <!-- ⚡ 闪电记录 -->
  <view class="section-header">
    <view class="flash-title-row">
      <t-icon name="flash" size="32rpx" color="#F0B44A" />
      <text class="section-title">闪电记录</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="flash-tabs">
    <view class="flash-tab {{flashCategory === 'all' ? 'active' : ''}}" bindtap="onFlashCategoryChange" data-value="all"
      >全部</view
    >
    <view
      class="flash-tab {{flashCategory === 'feeding' ? 'active' : ''}}"
      bindtap="onFlashCategoryChange"
      data-value="feeding"
      >喂养</view
    >
    <view
      class="flash-tab {{flashCategory === 'diaper' ? 'active' : ''}}"
      bindtap="onFlashCategoryChange"
      data-value="diaper"
      >排便</view
    >
    <view
      class="flash-tab {{flashCategory === 'sleep' ? 'active' : ''}}"
      bindtap="onFlashCategoryChange"
      data-value="sleep"
      >睡眠</view
    >
    <view
      class="flash-tab {{flashCategory === 'health' ? 'active' : ''}}"
      bindtap="onFlashCategoryChange"
      data-value="health"
      >体温</view
    >
  </view>

  <!-- 模板网格 4×N 紧凑布局 -->
  <view class="flash-grid">
    <view
      class="flash-item"
      wx:for="{{flashTemplates}}"
      wx:key="id"
      hover-class="flash-item-hover"
      bindtap="onFlashRecord"
      data-id="{{item.id}}"
    >
      <view class="flash-item-icon" style="background: {{item.iconBg}};">
        <image class="flash-item-svg" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <text class="flash-item-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 今日时间线 -->
  <view class="section-header">
    <text class="section-title">今日记录</text>
    <view wx:if="{{timelineEvents.length > 0}}" class="section-count-badge">
      <text class="section-count">{{timelineEvents.length}}条</text>
    </view>
  </view>

  <view class="timeline-section">
    <daily-timeline
      wx:if="{{timelineEvents.length > 0}}"
      events="{{timelineEvents}}"
      maxCount="{{8}}"
      clickable="{{true}}"
      bind:eventtap="onTimelineEventTap"
    />
    <view wx:else class="empty-state">
      <image class="empty-icon-img" src="/assets/icons/note.svg" mode="aspectFit" />
      <text class="empty-text">今日暂无记录</text>
      <text class="empty-hint">点击上方快捷按钮开始记录宝宝的一天</text>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-bottom"></view>

  <!-- 多宝宝切换悬浮球 -->
  <baby-switcher />
</view>
