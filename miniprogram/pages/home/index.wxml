<!--pages/home/index.wxml-->
<!--首页仪表盘-->

<view class="page-home">
  <!-- 宝宝信息卡片 -->
  <view class="baby-card gradient-primary">
    <view class="flex-row">
      <view class="baby-avatar-wrapper">
        <t-avatar
          wx:if="{{babyInfo}}"
          image="{{babyInfo.avatarUrl}}"
          size="large"
          shape="circle"
        />
        <t-avatar wx:else icon="user" size="large" shape="circle" />
      </view>
      <view class="baby-info ml-sm flex-1">
        <text class="baby-name">{{babyInfo.name || '添加宝宝信息'}}</text>
        <text class="baby-age">{{babyInfo.ageText || '请前往设置页完善信息'}}</text>
      </view>
    </view>
  </view>

  <!-- 今日数据摘要 -->
  <view class="section-title px-md mt-lg">今日概览</view>
  <view class="summary-grid px-md">
    <view class="summary-item card-sm animate-scale" bindtap="goToFeeding">
      <view class="summary-icon feeding-icon">🍼</view>
      <text class="summary-value">{{todaySummary.feedingCount}}</text>
      <text class="summary-label">喂养(次)</text>
    </view>
    <view class="summary-item card-sm animate-scale" bindtap="goToSleep">
      <view class="summary-icon sleep-icon">😴</view>
      <text class="summary-value">{{todaySummary.sleepDuration}}</text>
      <text class="summary-label">睡眠(小时)</text>
    </view>
    <view class="summary-item card-sm animate-scale" bindtap="goToDiaper">
      <view class="summary-icon diaper-icon">👶</view>
      <text class="summary-value">{{todaySummary.diaperCount}}</text>
      <text class="summary-label">排便(次)</text>
    </view>
    <view class="summary-item card-sm animate-scale" bindtap="goToHealth">
      <view class="summary-icon health-icon">🌡️</view>
      <text class="summary-value">{{todaySummary.lastTemperature}}</text>
      <text class="summary-label">体温(℃)</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section-title px-md mt-lg">快捷记录</view>
  <view class="quick-actions px-md flex-row">
    <view class="quick-btn animate-scale" bindtap="goToFeeding">
      <view class="quick-btn-icon" style="background: #EDE9FE;">🍼</view>
      <text class="quick-btn-text">喂奶</text>
    </view>
    <view class="quick-btn animate-scale" bindtap="goToSleep">
      <view class="quick-btn-icon" style="background: #DBEAFE;">😴</view>
      <text class="quick-btn-text">睡眠</text>
    </view>
    <view class="quick-btn animate-scale" bindtap="goToDiaper">
      <view class="quick-btn-icon" style="background: #D1FAE5;">👶</view>
      <text class="quick-btn-text">换尿布</text>
    </view>
    <view class="quick-btn animate-scale" bindtap="goToHealth">
      <view class="quick-btn-icon" style="background: #FEF3C7;">🌡️</view>
      <text class="quick-btn-text">量体温</text>
    </view>
  </view>

  <!-- 今日时间线 -->
  <view class="section-title px-md mt-lg">今日记录</view>
  <view wx:if="{{timeline.length > 0}}" class="timeline-list px-md">
    <view class="timeline-item card-sm animate-fade-in" wx:for="{{timeline}}" wx:key="id">
      <view class="timeline-dot" style="background: {{item.color}};"></view>
      <view class="timeline-content flex-1">
        <view class="flex-between">
          <text class="timeline-type">{{item.typeName}}</text>
          <text class="text-hint">{{item.timeText}}</text>
        </view>
        <text class="text-secondary mt-sm">{{item.summary}}</text>
      </view>
    </view>
  </view>
  <view wx:else class="empty-state">
    <text class="empty-state-text">今日暂无记录，点击上方快捷按钮开始记录吧</text>
  </view>
</view>
