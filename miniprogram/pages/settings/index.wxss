/* pages/settings/index.wxss */
/* 设置页样式 */

.page-settings {
  min-height: 100vh;
  background: #FBF8FF;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======= 宝宝信息卡片 ======= */
.baby-profile-card {
  position: relative;
  margin: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  min-height: 200rpx;
}

.profile-card-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #7C6FE0 0%, #A78BFA 50%, #C4B5FD 100%);
}

.profile-card-bg::after {
  content: '';
  position: absolute;
  top: -40rpx; right: -30rpx;
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.profile-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 32rpx;
}

.profile-avatar-area {
  flex-shrink: 0;
}

.profile-info-area {
  flex: 1;
  margin-left: 24rpx;
}

.profile-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.profile-age {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.profile-detail-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.profile-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.profile-edit-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ======= 数据统计 ======= */
.stats-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(124, 111, 224, 0.06);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.stats-total {
  font-size: 24rpx;
  color: #A78BFA;
  background: #F5F0FF;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #F5F0FF;
  border-radius: 16rpx;
  min-width: 120rpx;
}

.stats-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #7C6FE0;
}

.stats-label {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

/* 存储条 */
.storage-bar-section {
  padding-top: 16rpx;
  border-top: 1rpx solid #F0ECFF;
}

.storage-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.storage-bar-label {
  font-size: 24rpx;
  color: #6B7280;
}

.storage-bar-value {
  font-size: 24rpx;
  color: #9CA3AF;
}

.storage-bar-track {
  height: 12rpx;
  background: #F0ECFF;
  border-radius: 6rpx;
  overflow: hidden;
}

.storage-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #7C6FE0, #A78BFA);
  border-radius: 6rpx;
  transition: width 0.3s ease;
  min-width: 4rpx;
}

/* ======= 区块标签 ======= */
.section-label {
  padding: 28rpx 32rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #9CA3AF;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ======= 菜单卡片 ======= */
.menu-card {
  margin: 0 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(124, 111, 224, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  gap: 20rpx;
}

.menu-item-hover {
  background: #F5F0FF;
}

.menu-item-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.menu-item-content {
  flex: 1;
}

.menu-item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A2E;
}

.menu-item-title.danger {
  color: #F87171;
}

.menu-item-desc {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.menu-item-note {
  font-size: 28rpx;
  color: #9CA3AF;
}

.menu-divider {
  height: 1rpx;
  background: #F3F0FF;
  margin-left: 112rpx;
}

/* ======= 底部声明 ======= */
.footer-text {
  text-align: center;
  padding: 48rpx 32rpx 24rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  line-height: 1.8;
}

/* ======= 安全区 ======= */
.safe-bottom {
  height: 120rpx;
}

/* ======= 编辑弹窗 ======= */
.edit-popup {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F3F0FF;
}

.edit-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.edit-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F0FF;
}

.edit-popup-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

/* 头像选择 */
.form-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 32rpx;
}

.form-avatar-hint {
  font-size: 24rpx;
  color: #A78BFA;
  margin-top: 16rpx;
}

/* 表单组 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}

.required {
  color: #F87171;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F9F7FF;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: #A78BFA;
  background: #FFFFFF;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F9F7FF;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A2E;
}

.form-picker .placeholder {
  color: #9CA3AF;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #F9F7FF;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-textarea:focus {
  border-color: #A78BFA;
  background: #FFFFFF;
}

/* 底部保存按钮 */
.edit-popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F3F0FF;
}
